.Pill() {
	display: flex;
	align-items: center;
	justify-content: center;
	position: relative;
	gap: 0.25rem;
	font-size: 0.75rem;
	line-height: 0.75rem;
	font-weight: 500;
	background-color: @ColorGray100;
	padding: 0.25rem 0.5rem;
	width: fit-content;
	height: 1.5rem;
	transition: ease 0.2s background-color, ease 0.2s color, ease 0.2s box-shadow;
	box-shadow: inset 0 0 0 0 transparent;
	border-radius: 1rem;

	&.saDisabled {
		background: @ColorGray100;
		color: @ColorGray300;
		cursor: not-allowed;
	}

	&:has(:enabled) {
		cursor: pointer;

		.Hover({
			background-color: var(--Sa-Color-Primary100);
			color: var(--Sa-Color-Primary700);

			&.saOutline {
				box-shadow: inset 0 0 0 1px var(--Sa-Color-Primary600);
			}
		});

		&:active {
			background-color: var(--Sa-Color-Primary200);
			color: var(--Sa-Color-Primary800);
		}
	}

	&::before {
		content: "";
		height: 2.75rem;
		width: 100%;
		background-color: transparent;
		opacity: 0;
		position: absolute;
	}

	&.saSmall {
		height: 1.5rem;
		min-width: 2.5rem;
		border-radius: 0.75rem;
		padding: 0.25rem 0.5rem;
		gap: 0.25rem;
		font-size: 0.75rem;
		line-height: 0.75rem;
	}

	&.saMedium {
		min-width: 4rem;
		height: 2rem;
		border-radius: 1rem;
		padding: 0 0.75rem;
		gap: 0.5rem;
		font-size: 0.875rem;
		line-height: 0.875rem;
	}

	&.saLarge {
		min-width: 4rem;
		height: 2.5rem;
		border-radius: 1.25rem;
		padding: 0 0.75rem;
		gap: 0.5rem;
		font-size: 0.875rem;
		line-height: 0.875rem;
	}

	&.saOutline {
		box-shadow: inset 0 0 0 1px @ColorGray200;
	}

	&:has(:checked) {
		background-color: var(--Sa-Color-Primary600);
		color: @ColorWhite;

		&.saOutline {
			background-color: var(--Sa-Color-Primary100);
			color: var(--Sa-Color-Primary700);
			box-shadow: inset 0 0 0 1px var(--Sa-Color-Primary600);
		}
	}

	input {
		.AppearanceNone();
		border: none;
		margin: 0;
		padding: 0;
		padding-block: 0;
		padding-inline: 0;
		position: absolute;
		height: 100%;
		width: 100%;
		left: 0;
		top: 0;
		background: none;
		border-radius: 1rem;
		cursor: inherit;
	}
}

.PillHover() {
	.Hover({
		background-color: var(--Sa-Color-Primary100);
		color: var(--Sa-Color-Primary700);
	});

	&:active {
		background-color: var(--Sa-Color-Primary200);
		color: var(--Sa-Color-Primary800);
	}
}

.saPillGroup {
	display: flex;
	flex-direction: row;
	align-items: baseline;
	flex-wrap: wrap;
	gap: 0.5rem;
}