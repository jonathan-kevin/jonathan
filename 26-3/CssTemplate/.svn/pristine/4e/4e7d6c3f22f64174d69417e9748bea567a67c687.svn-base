.saMessageBanners {
	box-sizing: border-box;
	z-index: 1;
	overflow: auto;
	max-height: 6rem;

	* {
		box-sizing: border-box;
	}
}

.saLogin .saMessageBanners {
	position: fixed;
	display: flex;
	flex-direction: column;

	.saMessageBanner {
		width: 100vw;
	}
}

.saMessageBanner {
	.FlexCentered();
	position: relative;
	top: 0;
	right: 0;
	height: 2rem;
	font-size: 0.875rem;
	line-height: 1.25rem;
	font-weight: 600;
	z-index: @ZIndexMessageBanner;
	white-space: nowrap;
	left: 0;
	width: 100%;

	.saCloseButton {
		background-color: inherit;
		color: inherit;
	}

	.saIcon {
		color: inherit;
	}

	&.saInformational {
		background-color: @ColorBlue700;
		color: @ColorBlue50;
	}

	&.saWarning {
		background-color: @ColorYellow300;
		color: @ColorYellow900;
	}

	&.saError {
		background-color: @ColorRed600;
		color: @ColorRed50;
	}

	&.saSuccess {
		background-color: @ColorGreen600;
		color: @ColorGreen50;
	}

	.saBannerMessageWrapper {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 100%;
		position: absolute;
		top: 0;
		left: 0;
		padding: 0 2rem;
		overflow: hidden;

		.Hover({
			.saAnimated {
				animation-play-state: paused;
			}
		});
	}

	.saBannerMessage {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		justify-content: center;
		height: 2rem;

		&.saAnimated {
			justify-content: flex-start;
			text-align: left;
			animation: marquee ease-out infinite alternate;
		}
	}

	&.saFadeOut {
		animation: 2s ease marquee-out forwards;
	}

	&.saFadeIn {
		animation: 2s ease marquee-in forwards;
	}

	@keyframes marquee {
		from {
			transform: translateX(50%);
		}

		to {
			transform: translateX(-50%);
		}
	}

	@keyframes marquee-in {
		0% {
			opacity: 0;
			display: none;
			height: 0;
		}

		100% {
			opacity: 1;
			display: flex;
			height: 2rem;
		}
	}

	@keyframes marquee-out {
		0% {
			opacity: 1;
		}

		100% {
			opacity: 0;
			display: none;
			height: 0;
		}
	}

	.saIcon {
		font-size: 1rem;
	}

	.saCloseButton {
		.Button();
		.IconButtonSizeCompact();
		position: relative;
		margin-left: auto;
		background: transparent;
		z-index: 1;
		border-radius: 0;

		.Hover({
			.saIcon {
				color: @ColorWhite;
			}

			background: @ColorRed600;

			.saError& {
				background: @ColorRed700;
			}
		});

		&:active {
			.saIcon {
				color: @ColorWhite;
			}

			background: @ColorRed700;

			.saError& {
				background: @ColorRed800;
			}
		}
	}
}