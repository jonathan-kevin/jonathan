.saAlert,
.saAlert * {
	box-sizing: border-box;
}

.saLargeScreen .saAlert {
	min-width: 12.5rem;
	max-width: 25rem;
}

.saAlert {
	animation: ScaleIn 70ms ease-in;
	display: flex;
	flex-direction: column;
	position: relative;
	border-radius: 1rem;
	.BoxShadowStrong();
	justify-content: space-between;
	background: @ColorWhite;

	.saAlertHeader {
		min-height: 4.5rem;
		max-height: 8.5rem;
		display: flex;
		justify-content: center;
		align-items: center;
		border-radius: 1rem 1rem 0 0;

		.saIcon {
			display: flex;
			align-items: center;
			justify-content: center;
			color: @ColorWhite;
			font-size: 2.5rem;
			line-height: 2.5rem;
		}
	}

	.saAlertMessageWrapper {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 1rem;
	}

	.saAlertMessage {
		color: var(--Sa-Color-Text);
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		overflow-y: auto;
		overflow-x: hidden;
		word-break: break-word;

		p {
			font-size: 0.875rem;
			line-height: 1.375rem;
			font-weight: 400;
			white-space: pre-wrap;
		}
	}

	.saAlertHeading {
		line-height: 1;
	}

	.saButtons {
		display: flex;
		flex-direction: row;
		gap: 0.5rem;
		min-width: 0;
		flex-wrap: wrap;
	}

	.saAlertButton {
		.Button();
		.ButtonSizeModeDependent();
		min-width: 6.75rem;

		.saCompact & {
			min-width: 6rem;
		}

		.saSmallScreen & {
			min-width: 6.75rem;

		}
	}
}

.saAlert .saAlertHeader {
	.saError& {
		background: @ColorRed100;

		.saIcon {
			color: @ColorRed600;
		}
	}

	.saDestructive& {
		background-image: linear-gradient(45deg, lighten(@ColorRed600, 4) 25%, @ColorRed600 25%, @ColorRed600 50%, lighten(@ColorRed600, 4) 50%, lighten(@ColorRed600, 4) 75%, @ColorRed600 75%, @ColorRed600 100%);
		background-size: 6rem 6rem;
	}

	.saWarning& {
		background: @ColorYellow300;
		background-image: linear-gradient(45deg, lighten(@ColorYellow300, 8) 25%, @ColorYellow300 25%, @ColorYellow300 50%, lighten(@ColorYellow300, 8) 50%, lighten(@ColorYellow300, 8) 75%, @ColorYellow300 75%, @ColorYellow300 100%);
		background-size: 6rem 6rem;
	}


	.saInfo&,
	.saQuestion& {
		background-color: @ColorBlue100;

		.saIcon {
			color: @ColorBlue600;
		}
	}

	.saSuccess& {
		background:
			radial-gradient(50% 50% at 100% 0, @ColorGreen300 0% 5%, darken(@ColorGreen300, 4) 6% 15%, @ColorGreen300 16% 25%, darken(@ColorGreen300, 4) 26% 35%, @ColorGreen300 36% 45%,
				darken(@ColorGreen300, 4) 46% 55%, @ColorGreen300 56% 65%, darken(@ColorGreen300, 4) 66% 75%, @ColorGreen300 76% 85%, darken(@ColorGreen300, 4) 86% 95%,
				#0000 96%),
			radial-gradient(50% 50% at 0 100%, @ColorGreen300 0% 5%, darken(@ColorGreen300, 4) 6% 15%, @ColorGreen300 16% 25%, darken(@ColorGreen300, 4) 26% 35%, @ColorGreen300 36% 45%,
				darken(@ColorGreen300, 4) 46% 55%, @ColorGreen300 56% 65%, darken(@ColorGreen300, 4) 66% 75%, @ColorGreen300 76% 85%, darken(@ColorGreen300, 4) 86% 95%,
				#0000 96%),
			radial-gradient(50% 50%, @ColorGreen300 0% 5%, darken(@ColorGreen300, 4) 6% 15%, @ColorGreen300 16% 25%, darken(@ColorGreen300, 4) 26% 35%, @ColorGreen300 36% 45%,
				darken(@ColorGreen300, 4) 46% 55%, @ColorGreen300 56% 65%, darken(@ColorGreen300, 4) 66% 75%, @ColorGreen300 76% 85%, darken(@ColorGreen300, 4) 86% 95%,
				#0000 96%),
			radial-gradient(50% 50%, @ColorGreen300 0% 5%, darken(@ColorGreen300, 4) 6% 15%, @ColorGreen300 16% 25%, darken(@ColorGreen300, 4) 26% 35%, @ColorGreen300 36% 45%,
				darken(@ColorGreen300, 4) 46% 55%, @ColorGreen300 56% 65%, darken(@ColorGreen300, 4) 66% 75%, @ColorGreen300 76% 85%, darken(@ColorGreen300, 4) 86% 95%,
				#0000 96%) 12.5rem 12.5rem;
		background-size: 25rem 25rem;
		background-color: @ColorGreen300;
	}
}

.saSmallScreen .saAlert {
	margin-left: 1rem;
	width: calc(~'100% - 2rem');

	.saAlertButton {
		flex-grow: 1;
		max-width: 100%;
	}

}

@keyframes ScaleIn {
	0% {
		transform: scale(.4);
	}

	100% {
		transform: scale(1);
	}
}