.saProgressOuter {
	position: absolute;
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	display: flex;
	align-items: flex-start;
	justify-content: center;

	.saProgressWrapper {
		padding: 2rem;
		min-width: 12.5rem;
		max-width: 40rem;
		width: 80%;
		border-radius: 1.5rem;
		.BoxShadowMedium();
		.Border();
		background: @ColorWhite;
		position: relative;
		top: 12.5rem;

		.saProgressButton {
			.Button();
			.ButtonSizeModeDependent();
			.ButtonPrimary();
		}

		.saText {
			font-size: 0.875rem;
			margin-bottom: 0.5rem;
			word-break: break-all;
		}

		h3 {
			font-size: 1rem;
		}

		.saProgressMessage {
			overflow-y: auto;
			overflow-x: hidden;
			max-height: 35rem;
			padding-bottom: 1rem;
		}

		.saProgress {
			display: flex;
			flex-direction: column;
			position: relative;
			gap: 1rem;
			width: 100%;

			.saProgressHeading {
				font-weight: 600;
				color: var(--Sa-Color-Text);
			}

			.saProgressBarWrapper {
				height: 0.5rem;
				width: 100%;
				background: @ColorGray100;
				position: relative;
				border-radius: 0.25rem;
				overflow: hidden;
			}

			.saProgressBar {
				width: 100%;
				.AppearanceNone();
				height: 0.5rem;
				width: 100%;
				transition: ease width .2s;
				position: relative;

				&::-webkit-progress-bar {
					background: @ColorGray150;
					border-radius: 0.25rem;
				}

				&::-webkit-progress-value {
					background: var(--Sa-Color-Primary600);
					border-radius: 0.25rem;
					transition: width 0.2s;
				}

				&:not([value])::after {
					content: '';
					position: absolute;
					height: 0.5rem;
					border-radius: 0.25rem;
					min-width: 20%;
					left: 0;
					top: 0;
					background: var(--Sa-Color-Primary600);
					animation: saProgressIndeterminate 2s infinite ease;
				}
			}

			.saProgressText {
				display: inline-flex;
				color: var(--Sa-Color-TextSecondary);
				font-size: 0.75rem;
				word-break: break-all;
				gap: 0.5rem;
				flex-wrap: wrap;
				padding-right: 4rem;
				line-height: 1;
				min-height: 2rem;
				word-break: break-word;
			}

			.saDotCarouselWrapper {
				display: flex;
				align-items: center;
				position: absolute;
				bottom: 0.5rem;
				right: 1rem;
			}

			.saDotCarousel {
				position: relative;
				left: -624.9375rem;
				margin-left: 1rem;
				min-width: 0.5rem;
				height: 0.5rem;
				border-radius: 0.25rem;
				background-color: @ColorGray200;
				color: @ColorGray200;
				box-shadow: 624rem 0 0 0 @ColorGray200, 624.9375rem 0 0 0 @ColorGray200, 625.875rem 0 0 0 @ColorGray200;
				animation: saDotCarousel 1s infinite linear;
			}
		}
	}
}

.saCompact .saProgressWrapper {
	border-radius: 1rem;
	margin: 1rem;
	padding: 1rem;
}

.saSmallScreen .saProgressWrapper {
	border-radius: 1rem;
	margin: 1rem;
	width: 100%;
	padding: 1rem;
}

@keyframes saDotCarousel {
	0% {
	  box-shadow: 624rem 0 0 -1px @ColorGray200, 624.9375rem 0 0 1px @ColorGray200, 625.875rem 0 0 -1px @ColorGray200;
	}
	50% {
	  box-shadow: 625.875rem 0 0 -1px @ColorGray200, 624rem 0 0 -1px @ColorGray200, 624.9375rem 0 0 1px @ColorGray200;
	}
	100% {
	  box-shadow: 624.9375rem 0 0 1px @ColorGray200, 625.875rem 0 0 -1px @ColorGray200, 624rem 0 0 -1px @ColorGray200;
	}
}

@keyframes saProgressIndeterminate {

    0%,
    100% {
        left: 0;
    }

    50% {
        left: 80%;
    }
}