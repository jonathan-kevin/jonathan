.saTooltipRoot {
	background-color: var(--Sa-Color-TooltipBackground);
	color: var(--Sa-Color-TooltipText);
	max-width: min(37.5rem; 98vw);
	z-index: @ZIndexTooltip;
	border-radius: 0.5rem;
	padding: 0.5rem 0.75rem;
	font-size: 0.75rem;
	line-height: 1rem;
	pointer-events: none;
	box-sizing: border-box;
	overflow: hidden;
	word-break: break-word;

	.systemicon .icon {
		color: var(--Sa-Color-TooltipText) !important;
	}

	.saTooltipHeading {
		font-weight: 700;
	}
}

.saTooltipScreenReader {
	position: fixed;
	left: -9999px;
	visibility: hidden;
	pointer-events: none;
}