.saColumnManagerRoot {
	display: flex;
	justify-content: center;
	align-items: safe center;
	color: @ColorGray900;
	box-sizing: border-box;

	@media screen and (max-width: 400px) {
		.saSmallScreen & {
			overflow: auto;
		}
	}
}

.saColumnManager {
	display: flex;
	flex-direction: column;
	justify-content: space-between;
	position: relative;
	transform: scale(1);
	transition: transform 0.2s ease;
	min-width: 0;
	background-color: @ColorWhite;
	padding: 1rem;
	gap: 1rem;
	border-radius: 1rem;
	width: 25rem;
	min-height: 25rem;
	.BoxShadowSoft();
	.Border();
	.TabGroup();

	* {
		box-sizing: border-box;
	}

	.saEmptyState {
		display: none;
	}

	@media screen and (max-width: 400px) {
		.saSmallScreen & {
			min-height: fit-content;
		}
	}

	.saIsEmpty {
		.saEmptyState {
			display: flex;
			height: 22.5rem;
			justify-content: flex-start;

			.saDefaultButtonSecondary {
				margin-top: 1.5rem;
			}
		}

		.saSorter,
		.saResetButton {
			display: none;
		}
	}

	.saLargeScreen & {
		max-height: 80vh;
	}

	.saCloseColumnManager {
		.Button();
		.IconButtonSizeStandard();
		.ButtonGhost();
		position: absolute;
		top: 0.5rem;
		right: 0.5rem;
		font-size: 1.25rem;

		&::after {
			content: "";
			height: 3rem;
			width: 3rem;
			opacity: 0;
			position: absolute;
			top: -0.5rem;
			right: -0.5rem;
		}
	}

	.saColumnManagerTopRow {
		display: flex;
	}

	.saResetButton {
		margin-left: auto;
		width: fit-content;
	}

	.saButtonGroup {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		flex-wrap: wrap;

		button {
			min-width: 6rem;
		}
	}

	.saColumnManagerContent {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		font-size: 0.875rem;
		overflow: hidden;
		height: 100%;

		@media screen and (max-width: 400px) {
			.saSmallScreen & {
				min-height: fit-content;
			}
		}
	}

	.saCompact & .saTab {
		padding: 0 1rem;
	}

	.saColumnManagerPanelWrapper {
		overflow: auto;
	}

	.saColumnManagerPanel {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		overflow: hidden;
		height: 100%;

		.saSmallScreen & {
			overflow: unset;
		}
	}

	.saShowHideWrapper {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 0.5rem;
		padding-left: 0.625rem;
		cursor: pointer;
		margin-bottom: -0.25rem;
		width: fit-content;
	}

	.saColumnManagerHeader {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	ul {
		display: flex;
		flex-direction: column;
		overflow: auto;

		.saSmallScreen & {
			overflow: unset;
		}
	}

	.saColumnManagerDescription {
		font-size: 0.875rem;
		color: @ColorGray600;
		line-height: 1rem;
	}

	li {
		&.saDisabled {
			cursor: not-allowed;

			&:active {
				cursor: not-allowed;
			}

			label {
				pointer-events: none;
			}

			.saIcon {
				color: transparent;
				visibility: hidden;
			}
		}

		label {
			display: flex;
			width: 100%;
			padding: 0.25rem 0;
			background-color: transparent;
		}
	}

	li.saPlaceholder {
		height: 3rem;
		padding: 0.25rem 0;

		div {
			height: 2.5rem;
			background-color: @ColorGray150;
			border-radius: 0.5rem;
		}
	}

	.saColumnItem {
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		background-color: @ColorWhite;
		box-sizing: border-box;
		min-width: 0;
		border: 1px solid @ColorGray200;
		cursor: grab;
		padding: 0.5rem 0.75rem 0.5rem 0.5625rem;
		border-radius: 0.5rem;
		height: 2.5rem;
		background-color: @ColorGray100;
		width: 100%;

		&:active {
			cursor: grabbing;
		}

		.far {
			font-size: 1rem;
			color: @ColorGray500;
		}

		.saColumnItemButtons {
			display: flex;
			flex-direction: row;
			align-items: center;

			li {
				width: 2rem;
			}

			button {
				border: none;
				background-color: transparent;
				font-size: 1.25rem;

				.Hover({
					border: solid 1px @ColorBlue600;
				});
			}

			.saDragHandle {
				margin-left: 0.5rem;
			}
		}
	}

	.saSelected .saColumnItem {
		background-color: @ColorWhite;
	}

	.saItemInner {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 0.5rem;
		.UserSelectNone();

		input.saCheckbox::after {
			height: 3rem;
			width: 3rem;
		}

		span {
			font-size: 0.875rem;
			line-height: 1.125rem;
			.Ellipsis();
		}
	}

	.saItemLabel {
		font-size: 0.875rem;
		line-height: 1.125rem;
		pointer-events: none;
		.Ellipsis();
		padding-right: 0.5rem;
	}

	.saSmallScreen & {
		width: 100%;
		height: 95%;
		margin: 1rem;
		justify-content: space-between;

		.saTabGroup {
			max-height: 2.5rem;
		}

		.saSmallScreenDragHandle {
			position: absolute;
			width: 20%;
			height: 100%;
			height: 2.5rem;
			margin-top: 2px;
			right: 0;
		}
	}

	.saInputTextWrapper.saLabeled {
		margin: 0;
		width: 100%;

		.saStandard &,
		.saSmallScreen & {
			.saInputText,
			.saTrailingIconsWrapper {
				height: 2.5rem;
			}
		}
	}

	.saRow {
		display: flex;
		gap: 0.5rem;
		width: 100%;
	}

	.saRemoveColumnButton {
		.ButtonSecondary();
		.IconButtonSizeModeDependent();
		.StandardTransition();

		.saStandard & {
			min-width: 2.5rem;
		}
	}

	.saSorter {
		display: flex;
		align-items: center;
		flex-direction: column;
		gap: 1rem;
		overflow-y: auto;
		position: relative;
		min-height: 22.5rem;
	}

	.saSortDivider {
		.FlexCentered();
		gap: 0.5rem;
		width: 100%;
		font-size: 0.75rem;
		color: @ColorGray600;

		&::before,
		&::after {
			content: "";
			width: 100%;
			display: flex;
			height: 1px;
			background-color: @ColorGray200;
		}

		span {
			display: flex;
			white-space: nowrap;
		}
	}

	.saToggleGrid {
		display: flex;
		flex-direction: row;
		align-items: center;
		justify-content: center;
		min-height: 2.5rem;
		border-radius: 0.5rem;

		.saCompact & {
			min-height: 2rem;
		}

		input {
			position: absolute;
			inset: 0;
			opacity: 1;
			pointer-events: none;
			.AppearanceNone();
			transition: border-radius ease 0.2s;
		}

		label {
			display: flex;
			align-items: center;
			justify-content: center;
			height: 100%;
			margin: 0;
			padding: 0;
			min-height: 2.5rem;
			width: 100%;
			flex: 1;
			cursor: pointer;
			font-weight: 500;
			text-align: center;
			transition: ease background 0.2s, ease color 0.2s, ease border-color 0.2s,
				ease border-radius 0.2s, ease box-shadow 0.2s;
			background-color: @ColorWhite;
			border: 1px solid @ColorGray200;
			position: relative;
			min-width: 2.5rem;
			font-size: 1rem;
			color: @ColorGray600;

			&:first-child {
				border-radius: 0.5rem 0 0 0.5rem;
				margin-right: -1px;

				input {
					border-radius: 0.5rem 0 0 0.5rem;
				}
			}

			&:last-child {
				border-right-style: solid;
				border-width: 1px;
				border-radius: 0 0.5rem 0.5rem 0;

				input {
					border-radius: 0 0.5rem 0.5rem 0;
				}
			}

			.saCompact & {
				min-width: 2rem;
				min-height: 2rem;
			}

			.Hover({
				color: @ColorBlue600;
				background-color: @ColorBlue100;
				border-color: @ColorBlue600;
				z-index: 3;
			});

			&:active {
				color: @ColorBlue700;
				background-color: @ColorBlue200;
				border-color: @ColorBlue700;

				&:first-child {
					border-radius: 0.75rem 0 0 0.75rem;

					input {
						border-radius: 0.75rem 0 0 0.75rem;
					}
				}

				&:last-child {
					border-radius: 0 0.75rem 0.75rem 0;

					input {
						border-radius: 0 0.75rem 0.75rem 0;
					}
				}
			}

			&.saSelected {
				z-index: 2;
				background-color: @ColorBlue100;
				color: @ColorBlue600;
				border-color: @ColorBlue600;
			}
		}
	}
}
