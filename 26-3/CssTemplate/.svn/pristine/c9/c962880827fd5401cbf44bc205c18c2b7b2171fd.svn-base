@import "GridCommon.less";

.OverflowCoverFull(@position1, @position2) {
	&::before {
		.OverflowCover(@position1, @position2);
		background: @ColorWhite;
	}

	&::after {
		.OverflowCover(@position1, @position2);
		background: inherit;
		border-@{position1}-@{position2}-radius: 1rem;
		border-@{position1}: 1px solid @ColorGray200;
		border-@{position2}: 1px solid @ColorGray200;
	}
}

.OverflowCover(@position1, @position2) {
	content: '';
	width: 2rem;
	height: 2rem;
	display: flex;
	position: absolute;
	z-index: -1;
	@{position1}: -1px;
	@{position2}: -1px;
}

.saLargeScreen .saPivotGridWrapper.stickyheader {
	thead {
		position: sticky;
		z-index: 3;
		top: -1px;
	}

	thead tr:first-child {
		th:first-child {
			.OverflowCoverFull(top, left);
		}

		th:last-child {
			.OverflowCoverFull(top, right);
		}
	}

	tbody .saPivotGridHeading,
	thead .saPivotGridHeading.saPivotGridFiller:first-child {
		position: sticky;
		z-index: 2;
		left: 1px;
		box-shadow: -1px 0 0 @ColorGray200;
	}

	tbody tr:last-child th:first-child {
		.OverflowCoverFull(bottom, left);
	}
}

.saPivotGridWrapper {
	display: flex;
	flex-direction: column;
	align-items: flex-start;
	width: fit-content;

	&.saMultipleColumnButtons thead .saPivotGridHeadingInner {
		flex-direction: column;
		padding: 0.25rem 1.5rem;
		align-items: flex-start;
	}

	.saPivotGridFiller .saTopLeftCell {
		min-width: 2.5rem;
		height: 100%;
		display: flex;
		justify-content: center;
		align-items: center;

		.saPivotGridTopButton {
			.GridTopButton();
		}
	}

	.saPivotGrid {
		.GridTable();
		border-radius: 1rem;

		&.saHasColumnGroups .saPivotGridColumnGroup {
			border-top: none;
		}

		.saClickable {
			cursor: pointer;

			&:hover {
				background-color: var(--Sa-Color-GridRowHighlight);
			}
		}

		tbody tr:last-child {
			border-radius: 0 0 1rem 1rem;

			th:first-child {
				border-radius: 0 0 0 1rem;
			}

			td:last-child {
				border-radius: 0 0 1rem 0;
			}
		}
	}

	thead {
		padding: 0;

		tr {
			background: var(--Sa-Color-GridHead);

			&:first-child {
				border-radius: 1rem 1rem 0 0;

				.saPivotGridHeading {
					border-top: none;
				}

				th:first-child {
					border-radius: 1rem 0 0 0;
				}

				th:last-child {
					border-radius: 0 1rem 0 0;
				}
			}
		}
	}

	.saPivotGridHeading {
		.GridColumnHeader();
		min-height: 3rem;
		padding: 0;
		border-bottom: none;

		.saMultipleColumnButtons&:not(.saPivotGridFiller) {
			vertical-align: top;
		}


		&.saPivotGridFiller {
			background: @ColorWhite;
		}

		&:has(.saSorted) {
			background-color: var(--Sa-Color-GridHeadSorted);
		}
	}

	.saPivotGridGroupRow .saPivotGridFiller {
		border: none;

		&:has(.saTopLeftCell) {
			border-bottom: 1px solid @ColorGray150;
		}
	}

	.saPivotGridGroupRow+tr th:first-child:not(.saFirstInColumnGroup) {
		border-left: 1px solid @ColorGray150;
	}

	.saPivotGridHeadingInner {
		color: var(--Sa-Color-Text);
		font-weight: 500;
		display: flex;
		align-items: center;

		a {
			text-decoration: none;
			color: var(--Sa-Color-Text);
			cursor: pointer;

			.Hover({
				text-decoration: underline;
			});

			&:active {
				color: var(--Sa-Color-Primary600);
			}
		}
	}

	td {
		.GridCell();
		border-right: 1px solid @ColorGray150;
		text-align: left;

		&.right {
			text-align: right;
		}

		&.center {
			text-align: center;
		}
	}

	.saPivotGridHeadingInner,
	td span {
		align-items: center;
		gap: 0.5rem;
		flex-direction: row;
		.Ellipsis();
		padding: 0 1.5rem;
		min-height: 3rem;
	}

	tbody tr:last-child th:first-child {
		border-bottom: none;
		border-left: none;
	}

	thead tr th {
		font-weight: 500;
		max-width: 30rem;
	}

	tr {
		box-sizing: border-box;
		text-align: left;
		min-width: 0;
	}

	.saPivotGridGroupRow+tr th:first-child {
		border-top: 1px solid @ColorGray150;
	}

	.saPivotGrid tr :last-child {
		border-right: none;
	}

	.saPivotGridColumnGroup {
		.GridColumnGroup();
		border-radius: 0;

		&+.saPivotGridColumnGroup {
			border-left: none;
		}

		.saPivotGridHeadingInner,
		td span {
			min-height: 2.125rem;
			height: 2.125rem;
		}
	}

	.saLinkButtonWrapper {
		display: flex;
		align-items: center;
		height: 2rem;

		.saLinkFiller {
			height: 2rem;
			min-width: 2rem;
			width: 2rem;
		}
	}

	.saLinkButton {
		.GridButton();

		&.saDestructive {
			.Destructive(~'', @ColorWhite);
		}
	}

	caption {
		.GridCaption();
	}
}

.saCompact .saPivotGridWrapper {

	.saPivotGridHeadingInner,
	td span {
		padding: 0 0.5rem;
		min-height: 2rem;
	}

	&.saMultipleColumnButtons thead .saPivotGridHeadingInner {
		padding: 0.25rem 0.5rem;
	}

	th,
	td {
		min-height: 2rem;
	}

	th:has(.saSorted) {
		a {
			display: flex;
			align-items: center;
			gap: 0.375rem;

			.Hover({
				text-decoration: none;
			});

			span {
				.Hover({
					text-decoration: underline;
				});
			}
		}

		.saSortIcon {
			color: var(--Sa-Color-IconDark);
			font-size: 1rem;
		}
	}
}