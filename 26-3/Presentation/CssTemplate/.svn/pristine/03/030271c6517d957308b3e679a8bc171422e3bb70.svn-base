.saInlineDocumentWrapper {
	height: 100%;
	display: flex;
	flex-direction: column;
	gap: 0.5rem;

	.saInlineHeader {
		display: flex;
		flex-direction: row;
		gap: 0.5rem;

		.saInputTextWrapper {
			margin-right: 0;

			.saStandard & .saTrailingIconsWrapper,
			.saSmallScreen & .saTrailingIconsWrapper {
			height: 2.5rem;
			}
		}

		.saStandard & .saInputText,
		.saSmallScreen & .saInputText {
			height: 2.5rem;
		}

		.saDropdown {
			min-width: 6rem;
		}
	}

	.saInlineButtonGroup {
		display: flex;
		align-items: center;

		button {
			.FlexCentered();
			border: none;
			box-shadow: inset 0 0 0 1px var(--Sa-Color-InputFieldBorder);
			background-color: @ColorWhite;
			padding: 0;
			margin: 0;
			color: @ColorGray500;
			cursor: pointer;
			z-index: 1;
			.StandardTransition();
			.IconButtonSizeModeDependent();

			&:not(:first-child):not(:last-child) {
				border-radius: 0;
				margin-right: -1px;
			}

			&:first-child {
				border-radius: 0.5rem 0 0 0.5rem;
				margin-right: -1px;

				&:active {
					border-radius: 0.75rem 0 0 0.75rem;
				}
			}

			&:last-child {
				border-radius: 0 0.5rem 0.5rem 0;

				&:active {
					border-radius: 0 0.75rem 0.75rem 0;
				}
			}

			.Hover({
				background-color: @ColorBlue100;
				color: @ColorBlue600;
				box-shadow: inset 0 0 0 1px @ColorBlue600;
				z-index: 2;
			});

			&:focus-visible {
				background-color: @ColorBlue100;
				color: @ColorBlue600;
				box-shadow: inset 0 0 0 1px @ColorBlue600;
				z-index: 2;
			}

			&:active {
				background-color: @ColorBlue200;
				color: @ColorBlue700;
				box-shadow: inset 0 0 0 1px @ColorBlue700;
				z-index: 2;
			}

			&:disabled {
				pointer-events: none;
				box-shadow: inset 0 0 0 1px @ColorGray150;
				color: @ColorGray200;
				background-color: @ColorGray50;
				z-index: 0;
			}
		}
	}

	.saViewWrapper {
		min-height: 16rem;
	}

	img {
		max-width: 100%;
		max-height: 100%;
		.Border();
		border-radius: 0.5rem;
	}

	video {
		max-width: 100%;
		max-height: 100%;
		.Border();
		border-radius: 0.5rem;
	}

	.saInlineFrame {
		width: 100%;
		height: 100%;
		.Border();
		border-radius: 0.5rem;
		overflow: hidden;

		&.saEmpty {
			background-color: @ColorGray50;
			.FlexCentered();
			position: relative;
		}

		.saEmptyState {
			padding-bottom: 12.5rem;
			max-width: 25rem;
		}
	}

	a.saLink {
		.Link();
	}

	.saSmallScreen & {
		padding: 1rem;
	}

	.saMultiPartContent & {
		padding-right: 2px;
		padding-bottom: 2px;
	}
}