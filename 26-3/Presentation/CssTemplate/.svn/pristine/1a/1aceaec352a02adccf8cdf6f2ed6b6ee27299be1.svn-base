.FeaturedMenuItem(@n, @Color, @Color160, @Color180) {
	.saFeatured@{n} .saMenuItem {
		.saIconHolderFeatured {
			background: @Color180;

			.saIcon {
				color: @Color;
			}

			.saBadge {
				border-color: @Color180;
				background: @Color;
				color: @Color180;
			}
		}

		.Hover({
			background: @Color180;

			.saIconHolderFeatured {
				background: @Color;

				.saIcon {
					color: @ColorWhite;
				}

				.saBadge {
					border-color: @Color;
					background: @ColorWhite;
					color: @Color;
				}
			}

			.saMenuItemTextHeading,
			.saMenuItemTextDesc {
				color: @Color;
			}
		});

		&:active {
			background: @Color160;
		}
	}
}


.saMenuGroup {
	.saMenuBoxWrapper {
		.saFeatured {
			.saMenuItem {
				height: 4rem;
				gap: 1rem;
				border-radius: 0.75rem;

				&:active {
					border-radius: 1rem;

					.saIconHolderFeatured {
						border-radius: 0.75rem;
					}
				}
			}

			.saIconHolderFeatured {
				border-radius: 0.5rem;
				height: 3rem;
				min-width: 3rem;
				display: flex;
				transition: border-radius .2s ease, background .2s ease, color .2s ease;

				.saIcon {
					font-size: 1.5rem;
				}

				.saBadge {
					font-size: 0.75rem;
					height: 0.875rem;
					width: 0.875rem;
					min-width: 0.875rem;
					bottom: 0.375rem;
					right: 0.25rem;
				}
			}

			.saMenuItemText {
				display: flex;
				flex-direction: column;
				gap: 2px;
			}

			.saMenuItemTextHeading {
				.Ellipsis();

				display: flex;
				align-items: center;
				gap: 0.5rem;
			}

			.saMenuItemTextDesc {
				font-size: 0.75rem;
				line-height: 1.25;
				.Ellipsis();

				white-space: initial;
				word-wrap: initial;
				display: -webkit-box;
				-webkit-box-orient: vertical;
				-webkit-line-clamp: 2;
				color: var(--Sa-Color-Label-Brightness130);
			}
		}

		.FeaturedMenuItem(1,
			var(--Sa-Color-MenuGroupFeatureColor1), // Idle.
			var(--Sa-Color-MenuGroupFeatureColor1-Brightness180), // Active.
			var(--Sa-Color-MenuGroupFeatureColor1-Brightness190)); // Hover.

		.FeaturedMenuItem(2,
			var(--Sa-Color-MenuGroupFeatureColor2),
			var(--Sa-Color-MenuGroupFeatureColor2-Brightness180),
			var(--Sa-Color-MenuGroupFeatureColor2-Brightness190));

		.FeaturedMenuItem(3,
			var(--Sa-Color-MenuGroupFeatureColor3),
			var(--Sa-Color-MenuGroupFeatureColor3-Brightness180),
			var(--Sa-Color-MenuGroupFeatureColor3-Brightness190));

		.FeaturedMenuItem(4,
			var(--Sa-Color-MenuGroupFeatureColor4),
			var(--Sa-Color-MenuGroupFeatureColor4-Brightness180),
			var(--Sa-Color-MenuGroupFeatureColor4-Brightness190));

		.FeaturedMenuItem(5,
			var(--Sa-Color-MenuGroupFeatureColor5),
			var(--Sa-Color-MenuGroupFeatureColor5-Brightness180),
			var(--Sa-Color-MenuGroupFeatureColor5-Brightness190));
	}

	.saCompact & .saMenuBoxWrapper {
		li.saMenuItemWrapper.saFeatured .saMenuItem {
			height: 3.5rem;
			padding-left: 0.25rem;
			gap: 0.5rem;

			.saIconHolderFeatured {
				height: 3rem;
				min-width: 3rem;

				.saIcon {
					min-width: 1.625rem;
				}

				.saBadge {
					bottom: 0.375rem;
					right: 0.25rem;
				}
			}
		}

		.saFeatured .saMenuItemText {
			gap: 0;
		}
	}

	.saSmallScreen & .saMenuBoxWrapper {
		li.saMenuItemWrapper.saFeatured .saMenuItem {
			height: 3.5rem;
			padding-left: 0.25rem;
			gap: 0.5rem;
		}
	}

	.saMenuBoxDescription {
		font-size: 0.75rem;
		line-height: 1.25;
		color: var(--Sa-Color-Label-Brightness130);
		padding: 0 0.5rem;

		.saCompact & {
			padding: 0 0.25rem;
		}
	}
}