.saMultiAutoSearchWrapper {
	.StandardTransition();
	background: @ColorWhite;
	.UserSelectNone();
	width: 100%;
	display: flex;
	padding: 0;
	border: none;
	color: @ColorGray900;
	box-sizing: border-box;

	&.saHighlightFieldError:not(.saDisabled) {
		.saSelectedValueWrapper {
			background: @ColorRed100;
			outline: 2px solid @ColorRed600;
			outline-offset: -2px;

			.Hover ({
				outline: 2px solid @ColorRed700;
			});

			&:focus-within {
				outline: 2px solid @ColorRed700;
			}
		}
	}

	&.saHighlightFieldWarning:not(.saDisabled) {
		.saSelectedValueWrapper {
			background: @ColorYellow50;
			outline: 2px solid @ColorYellow300;
			outline-offset: -2px;

			.Hover ({
				outline: 2px solid @ColorYellow400;
			});

			&:focus-within {
				outline: 2px solid @ColorYellow400;
			}
		}
	}

	&.saDisabled .saSelectedValueWrapper {
		.DisabledControl();
		cursor: default;
		outline-color: transparent;

		input {
			.DisabledControl();
		}

		&:has(:hover) {
			outline-color: transparent;
		}

		.saTag {
			pointer-events: none;
		}
	}

	input[type="search"]::-webkit-search-decoration,
	input[type="search"]::-webkit-search-cancel-button,
	input[type="search"]::-webkit-search-results-button,
	input[type="search"]::-webkit-search-results-decoration {
		display: none;
	}

	input {
		font-size: 0.875rem;
		height: 1.5rem;
		min-width: 1.5rem;
		.AppearanceNone();
		background-color: transparent;
		padding: 0;
		margin: 0;
		outline: none;
		border: none;
		width: 1.5rem;
		color: @ColorGray900;
		font-family: 'Lexend', sans-serif;
		.StandardTransition();

		&::placeholder {
			color: @ColorGray600;
		}
	}

	&:focus-within .saSelectedValueWrapper {
		outline: 2px solid @ColorBlue600;
		outline-offset: -2px;
	}

	.saSelectedValueWrapper {
		display: flex;
		align-items: center;
		padding: 2px;
		padding-right: 1.75rem;
		gap: 0.25rem;
		min-height: 1.5rem;
		max-height: 17.5rem;
		.StandardTransition();
		flex-wrap: wrap;
		overflow-x: hidden;
		overflow-y: auto;
		border-radius: 0.5rem;
		outline: 1px solid var(--Sa-Color-InputFieldBorder);
		outline-offset: -1px;
		border: 2px solid transparent;
		overscroll-behavior: none;
		position: relative;
		cursor: text;

		li.saNewInput {
			flex-grow: 1;
			padding-left: 0.5rem;
		}

		&:has(:hover) {
			outline: 2px solid @ColorBlue600;
			outline-offset: -2px;
		}

		&:focus-within {
			background-color: @ColorBlue50;
		}

		.saTag {
			gap: 0.375rem;
			box-sizing: border-box;
			width: fit-content;
			max-width: 100%;
			background-color: @ColorGray50;
			border-radius: 0.25rem;
			cursor: pointer;
			font-size: 0.875rem;
			line-height: 0.875rem;
			padding: 0.25rem 0.5rem 0.25rem 0.5rem;
			min-height: 1.5rem;
			overflow-wrap: anywhere;
			.StandardTransition();
			box-shadow: inset 0 0 0 1px @ColorGray200;
			position: relative;
			align-items: baseline;

			&.saAnimate {
				animation: 0.2s saGrowIn ease;
			}

			@keyframes saGrowIn {
				0% {
					transform: scale(0.8);
					opacity: 0.4;
				}

				100% {
					transform: scale(1);
					opacity: 1;
				}
			}

			&.saFocus {
				background-color: @ColorRed50;
				color: @ColorRed600;
				box-shadow: inset 0 0 0 1px @ColorRed600;

				.saIcon {
					color: @ColorRed600;
				}
			}

			.saIcon {
				font-size: 0.75rem;
				line-height: 0.75rem;
				color: @ColorGray600;
				font-weight: 900;
				.StandardTransition();
			}

			&:active {
				background: @ColorRed50;
				color: @ColorRed600;
				border-radius: 0.75rem;

				.saIcon {
					color: @ColorRed600;
				}
			}

			.saLargeScreen & {
				.Hover({
					background: @ColorRed50;
					color: @ColorRed600;
					box-shadow: inset 0 0 0 1px @ColorRed600;

					.saIcon {
						color: @ColorRed600;
					}
				});

				&:active {
					background: @ColorRed600;
					color: @ColorWhite;

					.saIcon {
						color: @ColorWhite;
					}
				}
			}

			&:nth-last-child(2) {
				margin-right: -0.5rem;
			}

			/* Uncomment once compact mode design is finished for all controls.
			.saCompact & {
				height: 1.5rem;
				padding: 0 0.375rem 0 0.25rem;
				border-radius: 0.25rem;
			}*/
		}
	}
}