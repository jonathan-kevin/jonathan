.saTreeWrapper {
	*&, * {
		box-sizing: border-box;
	}

	.saCheckboxTreeInner {
		padding-left: 1.75rem;
	}

	label.saCheckboxWrapper {
		font-weight: 400;
		display: flex;
		flex-direction: row;
		gap: 0.5rem;
		box-sizing: border-box;
		align-items: center;
		position: relative;
		transition: ease border-radius .2s, ease color .2s, ease background-color .2s;

		span {
			font-size: 0.875rem;
			line-height: 1rem;
			word-break: break-word;
		}
	}
}

.saCheckboxTree {
	display: flex;
	flex-direction: column;
	width: 100%;
	position: relative;
	overflow-x: hidden;
	.UserSelectNone();

	.saDisabled & {
		background: @ColorGray50;
	}

	fieldset {
		display: flex;
		flex-direction: column;
		min-inline-size: min-content;
	}

	.saCheckboxOuter {
		position: relative;
		padding: 0;
		padding-inline-start: 0;
		padding-inline-end: 0;
		width: 100%;

		.saIcon {
			display: flex;
			align-items: center;
			justify-content: center;
			position: absolute;
			right: 0.25rem;
			top: 0.25rem;
			height: 2rem;
			width: 2rem;
			font-size: 0.875rem;
			color: @ColorGray600;
			background: transparent;
			border: none;
			cursor: pointer;
			border-radius: 0.25rem;
			padding: 0;

			&::after {
				content: '';
				height: 3rem;
				width: 3rem;
				position: absolute;
				top: -0.5rem;
				left: -0.5rem;
			}

			.Hover({
				&:not(.saSpinner):not(.saExpandingIcon) {
				color: @ColorBlue600;
				background: @ColorGray50;
				}
			});

			&:active {
				color: @ColorBlue600;
				background: @ColorGray100;
				border-radius: 0.5rem;
			}

			.saDisabled & {
				color: @ColorGray200;
			}
		}
	}

	.saIcon:before {
		transition: color ease .2s, border-radius ease .2s, background-color ease .2s, transform ease .2s;
	}

	.saOpen .saIcon:before {
		transform: rotate(-180deg);
	}

	label.saCheckboxWrapper:not(:has(.saCheckbox:disabled)) {
		cursor: pointer;

		.Hover({
			background: @ColorGray50;
		});

		&:active {
			background: @ColorGray100;
			border-radius: 0.75rem;
		}
	}

	.saCheckboxWrapper {
		min-height: 2.5rem;
		border-radius: 0.5rem;
		padding: 0.5rem 2.5rem 0.5rem 0.5rem;
		background-color: transparent;

		input.saCheckbox::after {
			// Smaller focus ring to not have it overflow the element and get hidden which looks bad.
			height: 1.875rem;
			min-width: 1.875rem;
		}
	}
}

.saCompact {
	.saCheckboxTree {
		.saCheckboxWrapper {
			min-height: 2rem;
			padding: 0.375rem 2.5rem 0.375rem 0.375rem;
		}

		.saCheckboxOuter button.saIcon {
			top: 0;
			right: 0;

			&::after {
				content: none;
			}
		}

		.saInputTextWrapper {
			.saLeadingIcon {
				position: absolute;
				top: 0.5rem;
				left: 0;
				z-index: 1;
				font-size: 1rem;
			}
		}

		.saInputText {
			height: 2rem;
		}
	}
}

.saSmallScreen .saCheckboxTreeWrapper {
	max-height: none;

	input.saCheckbox,
	input.saInputText {
		width: unset; /* Reset width set to 98.5% for all input elements. */
	}

	.saCheckboxTree {
		.saCheckboxWrapper {
			min-height: 2.5rem;
			padding: 0.5rem;
			border-radius: 0.5rem;
			box-shadow: none;
			width: 100%;
			background: transparent;
		}

		label.saCheckboxWrapper:not(:has(.saCheckbox:disabled)) {
			.Hover({
				background: inherit;
			});

			&:active {
				background: @ColorGray100;
				box-shadow: none;
			}
		}

		.saCheckboxOuter button.saIcon {
			.Hover({
				background: transparent;
				color: @ColorGray600;
			});
		}

		.saInputText {
			font-size: 1rem;
		}
	}
}

