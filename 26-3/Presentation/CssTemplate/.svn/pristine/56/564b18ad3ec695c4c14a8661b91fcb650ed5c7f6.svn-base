/*
 * Menu item specific styles for general menu item laout.
 */
.fixedSizePopup() {
	top: 50%;
	left: 50%;
	transform: translate(-50%, -50%);
	border-radius: 0.5rem;
	.BoxShadowStrong();
}

.saMenuItemPopup {
	position: absolute;

	.saLargeScreen &.saSmall  {
		width: 25rem;
		height: 25rem;
		max-height: 75%;
		max-width: 100%;

		.fixedSizePopup();
	}

	.saLargeScreen &.saMedium  {
		width: 50rem;
		height: 50rem;
		max-height: 85%;
		max-width: 100%;

		.fixedSizePopup();
	}

	&.saLarge {
		top: 3.5rem;
		right: 1rem;
		bottom: 1rem;
		left: 1rem;
		border-radius: 0.5rem;
		transform: none;

		box-shadow: -1rem -0.875rem 1.875rem -0.625rem fade(@ColorGray900, 20);
	}

	.saSmallScreen & {
		left: 0;
		right: 0;
		top: 0;
		bottom: 0;
		border: 0;

		width: none;
		height:none;

		border-radius: 8x 0.5rem 0 0;
	}

	background-color: @ColorWhite;
}

.saMenuItemPopup iframe {
	width: 100%;
	height: 100%
}

.saMenuItemPopup form {
	display: none
}

.smallscreen .saMenuItemPopup {
	left: 0;
	right: 0;
	top: 0;
	bottom: 0;
	border: 0
}

body.saPopup .saMenuItemPopup {
	right: 0
}

body.saPopup::before {
	background: 0 0 !important
}