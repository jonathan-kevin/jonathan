.NavigationBarBadgeSizeStandard() {
	height: 0.875rem;
	min-width: 0.875rem;
	font-size: 0.625rem;
	right: -0.25rem;
	bottom: -0.25rem;
	z-index: 2;
}

.NavigationBarBadgeSizeCompact() {
	right: -0.375rem;
	bottom: -0.25rem;
	border: 1px solid;
	height: 0.75rem;
	min-width: 0.75rem;
	font-size: 0.5rem;
}

.NavigationBar() {
	.ContextMenu();
	.BadgeCount();

	.saBadge {
		.NavigationBarBadgeSizeStandard();
	}

	.saNavigationBar {
		display: flex;
	}

	.saTopButtons {
		gap: 0.5rem;
		display: flex;
		flex-wrap: nowrap;
		align-items: center;
		width: 100%;
		flex-shrink: 99;
	}

	.saCollectorWrapper {
		display: flex;
	}

	.saActionLinks {
		display: flex;
		gap: 0.5rem;

		.saMoreButton {
			.Button();
			.ButtonSecondary();
			.IconButtonSizeModeDependent();
			.Border();
			position: relative;

			&.saOpen {
				background-color: var(--Sa-Color-SecondaryButtonBackgroundActive);
				border-color: var(--Sa-Color-SecondaryButtonBorderHover);

				.saIcon {
					color: var(--Sa-Color-IconHover);
				}
			}

			.saBadgeCount {
				position: absolute;
				top: -0.25rem;
				right: -0.25rem;
			}
		}

		.saActionLink {
			.Button();
			.ButtonSizeModeDependent();
			min-width: 3.5rem;

			&.saInactive,
			&.saInactive:hover,
			&.saInactive:active {
				cursor: default;
				background: @ColorGray100;
				color: @ColorGray400;
				border-color: transparent;
				border-radius: 0.5rem;

				.saIcon {
					color: @ColorGray400;
				}

				.saBadge {
					color: @ColorGray600;
					background: @ColorGray100;
					border-color: @ColorGray600;
				}
			}
		}
	}

	.saNavigationLinks {
		display: flex;
		align-items: center;

		.saMoreButton {
			.Button();
			.IconButtonSizeCompact();
			.ButtonGhost();
			position: relative;

			&.saOpen {
				background: @ColorGray50;
				color: @ColorBlue600;

				.saIcon {
					color: var(--Sa-Color-IconHover);
				}
			}

			.saBadgeCount {
				position: absolute;
				top: -0.25rem;
				right: -0.25rem;
			}
		}

		.saNavigationLink {
			.Button();
			.ButtonSizeCompact();
			display: flex;
			gap: 0.5rem;
			align-items: center;
			color: var(--Sa-Color-Label);
			padding: 0.375rem 0.75rem;
			height: 2rem;
			border: none;
			background: transparent;
			margin: 0;
			font: inherit;
			cursor: pointer;
			transition: ease background .2s, ease color .2s, ease border-radius .2s;
			text-decoration: none;
			border-radius: 0;

			.saIcon {
				color: var(--Sa-Color-Icon);
			}

			.saBadge {
				.NavigationBarBadgeSizeCompact();
				border-color: @ColorWhite;
				color: @ColorWhite;
				background-color: var(--Sa-Color-Icon);
			}

			&.saButtonPrimary {
				color: var(--Sa-Color-Link);
				position: relative;

				.saIcon {
					color: var(--Sa-Color-Link);
				}

				.saBadge {
					background-color: var(--Sa-Color-Link);
				}
			}

			.Hover({
				color: var(--Sa-Color-Link);
				text-decoration: underline;

				.saIcon {
					color: var(--Sa-Color-Link);
				}

				.saBadge {
					background-color: var(--Sa-Color-Link);
				}
			});

			&:active {
				color: var(--Sa-Color-Link-Brightness80);
				border-radius: 0;

				.saIcon {
					color: var(--Sa-Color-Link-Brightness80);
				}

				.saBadge {
					background-color: var(--Sa-Color-Link-Brightness80);
				}
			}

			&.saButtonPrimary+.saNavigationLink {
				border-left: 1px solid @ColorGray200;
			}

			&.saInactive,
			&.saInactive:hover,
			&.saInactive:active {
				cursor: not-allowed;
				color: @ColorGray400;
				text-decoration: none;

				.saIcon {
					color: @ColorGray400;
				}

				.saBadge {
					color: @ColorGray400;
					background: @ColorWhite;
					border-color: @ColorGray400;
				}
			}
		}
	}

	.saBrowseButtons {
		display: flex;
		margin-right: 0;

		.saBrowseButton {
			.Button();
			.ButtonSecondary();
			.IconButtonSizeModeDependent();
			position: relative;

			.Hover({
				z-index: 1;
			});

			&.saPrevious {
				border-radius: 0.5rem 0 0 0.5rem;
				margin-right: -1px;

				&:active {
					border-radius: 0.75rem 0 0 0.75rem;
				}
			}

			&.saNext {
				border-radius: 0 0.5rem 0.5rem 0;

				&:active {
					border-radius: 0 0.75rem 0.75rem 0;
				}
			}

			&.saDisabled {
				opacity: .4;
				pointer-events: none;
			}
		}
	}

	.saLargeScreen & {
		.saActionLink {
			max-width: 33rem;
		}
	}

	.saStandard & {
		.saActionLinks .saContextMenu {
			top: 3.5rem;
		}

		.saNavigationLinks .saContextMenu {
			top: 2.75rem;
		}
	}

	.saCompact & {
		.saContextMenu 	.saContextMenuItem {
			font-size: 0.875rem;
		}

		.saActionLinks .saContextMenu {
			top: 2.75rem;
		}

		.saNavigationLinks .saContextMenu {
			top: 2.75rem;
		}

		.saBadge {
			.NavigationBarBadgeSizeCompact();
		}
	}

	.saSmallScreen & {
		.saActionLink {
			max-width: calc(~'100% - 4.5rem');
			min-width: 5.5rem;
		}

		.saBrowseButtons {
			margin-left: 0.5rem;
		}

		.saTopButtons {
			justify-content: space-between;
			width: 100%;
			flex-basis: 100%;
			box-sizing: border-box;
		}
	}
}

.saContextMenu .saActionLinkList {
	display: flex;
	flex-direction: column;
}

.saSmallScreen .saSmallScreenMenu {
	display: flex;
	height: fit-content;
	width: 100%;

	.saContextMenu {
		border: none;
		box-shadow: none;
		position: relative;
		height: fit-content;
		.BadgeCount();
	}

	.saBadge {
		.NavigationBarBadgeSizeStandard();
	}
}