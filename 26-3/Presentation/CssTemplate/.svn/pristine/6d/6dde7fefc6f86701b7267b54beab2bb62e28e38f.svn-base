.saToggleWrapper {
	display: flex;
	gap: 0.5rem;
	cursor: pointer;
	user-select: none;
	align-items: center;
	justify-content: space-between;
	min-height: 2rem;

	&.saDisabled {
		cursor: default;
	}

	.saToggleLabelWrapper {
		display: flex;
		flex-direction: column;
		justify-content: center;
	}

	.saToggleLabel {
		display: flex;
		font-size: 0.875rem;
		line-height: 0.875rem;
	}

	.saToggleDescription {
		display: flex;
		height: 0.75rem;
		font-size: 0.75rem;
		font-variant-numeric: tabular-nums;
		color: var(--Sa-Color-TextSecondary);
	}

	&:not(.saDisabled):active .saToggle {
		&::after {
			right: 0.875rem;
			width: 1.5rem;
		}

		&:checked::after {
			right: 2px;
			width: 1.5rem;
		}
	}

	.saToggle {
		position: relative;
		min-width: 2.5rem;
		height: 1.5rem;
		overflow: hidden;
		border-radius: 0.75rem;
		.AppearanceNone();

		&::before {
			//Track
			content: '';
			min-height: 1.5rem;
			min-width: 2.5rem;
			border-radius: 0.75rem;
			background: @ColorGray200;
			box-shadow: inset 0 0 0 1px fade(@ColorGray900, 10);
			transition: ease background-color .2s, ease box-shadow .2s;
			position: absolute;
		}

		&::after {
			//Knob
			content: '';
			height: 1.25rem;
			width: 1.25rem;
			border-radius: 0.625rem;
			background: @ColorWhite;
			box-shadow:
				inset 0 0 0 1px @ColorGray50,
				0 1px 2px 0 fade(@ColorGray900, 60);
			right: 1.125rem;
			top: 2px;
			position: absolute;
			transition: ease all .2s;
		}

		//Unchecked
		.Hover({
			&::before {
				background: @ColorGreen100;
			}
		});

		&:active::before {
			background: @ColorGreen200;
		}

		&:active::after {
			right: 0.875rem;
			width: 1.5rem;
		}

		//Checked
		&:checked {
			&::before {
				background: @ColorGreen400;
			}

			&::after {
				right: 2px;
			}

			.Hover({
				&::before {
					background: @ColorGreen300;
				}
			});

			&:active::before {
				background: @ColorGreen200;
			}

			&:active::after {
				right: 2px;
				width: 1.5rem;
			}

			//Disabled
			.saDisabled& {
				&::before {
					background: @ColorGray600;
				}

				&::after {
					background: @ColorGray200;
					box-shadow:
						inset 0 0 0 1px fade(@ColorGray900, 20),
						0 1px 2px 0 fade(@ColorGray900, 60);
				}

				.Hover({
					&::before {
						background: @ColorGray600;
					}
				});

				&:active::before {
					background: @ColorGray600;
				}

				&:active::after {
					right: 2px;
					width: 1.25rem;
				}
			}
		}

		//Disabled
		.saDisabled& {
			cursor: default;
			&::before {
				background: @ColorGray200;
			}

			&::after {
				background: @ColorGray50;
				box-shadow:
					inset 0 0 0 1px fade(@ColorGray900, 10),
					0 1px 2px 0 fade(@ColorGray900, 20);
			}

			.Hover({
				&::before {
					background: @ColorGray200;
				}
			});

			&:active::before {
				background: @ColorGray200;
			}

			&:active::after {
				right: 1.125rem;
				width: 1.25rem;
			}
		}

	}
}

.saSmallScreen {
	.saToggleWrapper {
		gap: 0.5rem;

		&:active .saToggle {
			&::after {
				right: 1.125rem;
				width: 2.25rem;
			}

			&:checked::after {
				right: 2px;
				width: 2.25rem;
			}
		}

		.saToggle {
			min-width: 3.5rem;
			height: 2rem;

			&::before {
				//Track
				min-height: 2rem;
				min-width: 3.5rem;
				border-radius: 1rem;
			}

			&::after {
				//Knob
				height: 1.75rem;
				width: 1.75rem;
				border-radius: 0.875rem;
				right: 1.625rem;
			}

			//Unchecked
			&:active::after {
				right: 1.125rem;
				width: 2.25rem;
			}

			//Checked
			&:checked {
				&::after {
					right: 2px;
					width: 1.75rem;
				}

				&:active::after {
					right: 2px;
					width: 2.25rem;
				}
			}
		}
	}
}