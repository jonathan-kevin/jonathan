.saInlineDocumentWrapper {
	height: 100%;
	display: flex;
	flex-direction: column;
	gap: 0.5rem;

	.saInlineHeader {
		display: flex;
		flex-direction: row;
		gap: 0.5rem;

		.saInputTextWrapper {
			margin-right: 0;

			.saStandard & .saTrailingIconsWrapper {
			height: 2.5rem;
			}
		}

		.saStandard & .saInputText {
			height: 2.5rem;
		}

		.saDropdown {
			min-width: 6rem;
		}
	}

	.saInlineButtonGroup {
		display: flex;
		align-items: center;

		button {
			.FlexCentered();
			border: none;
			box-shadow: inset 0 0 0 1px var(--Sa-Color-InputFieldBorder);
			background-color: @ColorWhite;
			padding: 0;
			margin: 0;
			color: var(--Sa-Color-Icon);
			cursor: pointer;
			z-index: 1;
			.StandardTransition();
			.IconButtonSizeModeDependent();

			&:not(:first-child):not(:last-child) {
				border-radius: 0;
				margin-right: -1px;
			}

			&:first-child {
				border-radius: 0.5rem 0 0 0.5rem;
				margin-right: -1px;

				&:active {
					border-radius: 0.75rem 0 0 0.75rem;
				}
			}

			&:last-child {
				border-radius: 0 0.5rem 0.5rem 0;

				&:active {
					border-radius: 0 0.75rem 0.75rem 0;
				}
			}

			.Hover({
				background-color: var(--Sa-Color-Primary100);
				color: var(--Sa-Color-Primary600);
				box-shadow: inset 0 0 0 1px var(--Sa-Color-Primary600);
				z-index: 2;
			});

			&:focus-visible {
				background-color: var(--Sa-Color-Primary100);
				color: var(--Sa-Color-Primary600);
				box-shadow: inset 0 0 0 1px var(--Sa-Color-Primary600);
				z-index: 2;
			}

			&:active {
				background-color: var(--Sa-Color-Primary50);
				color: var(--Sa-Color-Primary700);
				box-shadow: inset 0 0 0 1px var(--Sa-Color-Primary700);
				z-index: 2;
			}

			&:disabled {
				pointer-events: none;
				box-shadow: inset 0 0 0 1px @ColorGray150;
				color: @ColorGray200;
				background-color: @ColorGray50;
				z-index: 0;
			}
		}
	}

	.saViewWrapper {
		min-height: 16rem;
	}

	img {
		max-width: 100%;
		max-height: 100%;
		.Border();
		border-radius: 0.5rem;
	}

	video {
		max-width: 100%;
		max-height: 100%;
		.Border();
		border-radius: 0.5rem;
	}

	.saInlineFrame {
		width: 100%;
		height: 100%;
		.Border();
		border-radius: 0.5rem;
		overflow: hidden;

		&.saEmpty {
			background-color: @ColorGray50;
			.FlexCentered();
			position: relative;
		}

		.saEmptyState {
			padding-bottom: 12.5rem;
			max-width: 25rem;
		}
	}

	.saSmallScreen & {
		padding: 1rem;
	}

	.saMultiPartContent & {
		padding-right: 2px;
		padding-bottom: 2px;
	}
}

.saInlineDownload {
	.FlexCentered();
	flex-direction: column;
	color: var(--Sa-Color-Text);
	text-align: center;
	margin-top: 5rem;

	.saIcon {
		.FlexCentered();
		font-size: 1.5rem;
		border-radius: 0.5rem;
		margin-bottom: 1rem;
		height: 3rem;
		width: 3rem;
		.FileIconColored();
	}

	.Hover({
		.saInlineDownloadButton {
			background-color: var(--Sa-Color-Primary700);
		}
	});

	&:active {
		.saInlineDownloadButton {
			background-color: var(--Sa-Color-Primary800);
			border-radius: 0.75rem;
		}
	}
}

.saInlineDownloadHeading {
	font-size: 1rem;
	line-height: 1;
	font-weight: 600;
	margin-bottom: 0.5rem;
	overflow-wrap: anywhere;
}

.saInlineDownloadDescription {
	font-size: 0.875rem;
	line-height: 1.25rem;
	margin-bottom: 1rem;
	color: var(--Sa-Color-TextSecondary);
}

.saInlineDownloadButton {
	.FlexCentered();
	gap: 0.5rem;
	font-size: 0.875rem;
	padding: 0 1rem;
	height: 2.75rem;
	color: @ColorWhite;
	background-color: var(--Sa-Color-Primary600);
	border-radius: 0.5rem;
	.StandardTransition();
}