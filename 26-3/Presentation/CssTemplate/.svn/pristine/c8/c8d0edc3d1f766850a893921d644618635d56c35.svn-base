.saAppInstall {
	.saAppInstructions {
		width: fit-content;
		box-sizing: border-box;

		.saSmallScreen & {
			padding: 1rem;
			width: 100%;
		}

		p {
			margin: 0.5rem 0;
		}

		h2 {
			margin: -0.25rem 0 0.5rem 0;
		}

		ol {
			margin: 0;
			padding-inline-start: 1.5rem;
		}

		li {
			margin-top: 1rem;
		}

		img {
			max-width: 100%;
			height: auto;
			margin-right: 1rem;
		}

		.saDefaultButtonPrimary {
			margin-top: 1.5rem;

			.saSmallScreen & {
				width: 100%;
			}
		}
	}
}