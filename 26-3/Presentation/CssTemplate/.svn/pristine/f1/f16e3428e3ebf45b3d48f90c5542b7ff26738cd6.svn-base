.saSelectionArea {
	position: absolute;
	background: rgba(var(--Sa-Color-Primary600), 0.2);
	box-shadow: inset 0 0 0 1px var(--Sa-Color-Primary600);
	pointer-events: none;
	z-index: 90;
}

.saPdfTemplateEditor {
	display: flex;
	width: 100%;
	border-radius: 1rem 0.25rem 0.25rem 1rem;
	overflow: hidden;
	border: 1px solid @ColorGray200;
	box-sizing: border-box;
	outline: none;

	* {
		box-sizing: border-box;
	}

	.saPdfPagination {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.saPageButton {
		.Button();
		.IconButtonSizeModeDependent();
		.ButtonSecondary();
		position: relative;

		&::after {
			content: '';
			height: 3rem;
			width: 3rem;
			position: absolute;
			opacity: 0;
		}

		&:disabled {
			background: transparent;
			border-color: transparent;

			.saIcon {
				color: @ColorGray200;
			}
		}
	}

	.saPdfTemplateEditorSidebar {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: 0.5rem;
		width: 16.5rem;
		min-width: 16.5rem;
		padding: 0.75rem;
		border-right: 1px solid @ColorGray200;

		.saLastSavedText {
			height: 1.25rem;
			color: var(--Sa-Color-TextSecondary);
			font-size: 0.75rem;
			padding-left: 0.25rem;
		}
	}

	.saInputTextWrapper {
		margin-right: 0.5rem;

		.saLabeledLabel {
			top: 0.375rem;
			left: 0.5rem;
			width: 100%;
		}

		.saTrailingIconsWrapper {
			height: 2.5rem;
		}

		.saInputText {
			height: 2.5rem;
			padding-top: 0.75rem;
			padding-left: 0.5rem;
			width: 4rem;
			min-width: 4rem;

			&.saDropdown {
				width: fit-content;
				min-width: 8rem;
			}
		}
	}

	.saAvailableValuesWrapper {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
		height: 100%;
		overflow: auto;
	}

	.saAvailableValuesGroupWrapper {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 0.25rem;
	}

	.saAvailableValuesGroupName {
		font-size: 0.75rem;
		line-height: 0.75rem;
		color: var(--Sa-Color-TextSecondary);
		font-weight: 400;
	}

	.saAvailableValuesGroup {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.saAvailableValue {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		justify-content: space-between;
		padding: 0.5rem;
		height: 2rem;
		border: 1px solid @ColorGray200;
		border-radius: 0.5rem;
		background: @ColorWhite;
		position: relative;
		cursor: grab;
		.UserSelectNone();

		.saIcon {
			font-size: 1.125rem;
		}

		.saIconsWrapper {
			display: flex;
			gap: 0.5rem;
		}

		.saInfoIcon {
			color: var(--Sa-Color-Icon);
		}

		.saCheckMark {
			display: none;
			color: @ColorPurple600;
		}

		&.saPlaced {
			cursor: default;

			.saDragHandle {
				opacity: 0;
			}

			.saCheckMark {
				display: flex;
				cursor: pointer;
			}

			&.saMarked {
				background: @ColorPurple50;
				border-color: @ColorPurple600;
				box-shadow: 0 0 0 0.25rem @ColorPurple200;
				color: @ColorPurple600;

				.saIcon {
					color: @ColorPurple600;
				}
			}
		}

		&.saDisabled {
			background: @ColorGray100;
			color: @ColorGray300;

			.saIcon {
				color: @ColorGray300;
			}
		}
	}

	.saAvailableValueLabel {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		overflow: hidden;

		label {
			font-size: 0.875rem;
			pointer-events: none;
			white-space: nowrap;
		}

		.saIcon {
			color: var(--Sa-Color-Icon);
		}
	}

	.saPdfTemplate {
		width: 100%;
		height: 100%;
		display: flex;
		flex-direction: column;
		background: @ColorGray100;
		overflow: auto;
		position: relative;
	}

	.saCanvasOuter {
		height: fit-content;
		width: 100%;
	}

	.saCanvasInner {
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		padding: 0.5rem;
	}

	.saCanvasWrapper {
		display: flex;
		position: relative;
	}

	.saPdfTemplateToolbarWrapper {
		min-height: 3.5rem;
		height: fit-content;
		width: 100%;
		position: sticky;
		top: 0;
		left: 0;
		z-index: 1;
	}

	.saHidden .saPdfTemplateToolbar {
		transform: translateY(-100%);
	}

	.saPdfTemplateToolbar {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		width: 100%;
		background: @ColorWhite;
		padding: 0.5rem;
		justify-content: space-between;
		transition: ease transform .2s;
		box-shadow: inset 0 -1px 0 0 @ColorGray200;

		ul {
			display: flex;
			flex-direction: row;
			flex-wrap: wrap;
		}

		input[type="number"]::-webkit-inner-spin-button {
			display: none;
		}

		input[type="number"] {
			appearance: textfield;
			-moz-appearance: textfield;
			-webkit-appearance: textfield;
		}
	}

	.saToolbarButton {
		.Button();
		.ButtonGhost();
		.IconButtonSizeStandard();
		position: relative;

		&::after {
			content: '';
			height: calc(100% + 1rem);
			width: 100%;
			position: absolute;
		}

		&:disabled {
			.saIcon {
				color: @ColorGray300;
			}

			background-color: transparent;
		}
	}

	.saInputPair {
		border-right: 1px solid @ColorGray200;
		flex-wrap: wrap;

		&.saHideBorder {
			border-right: none;
		}
	}

	.saNumberStepper {
		font-size: 1rem;
	}

	.saPdfTemplateToolbarAlign {
		flex-wrap: wrap;
	}

	.saToolbarFont {
		gap: 0.5rem;
	}

	.saPlaceholder {
		position: absolute;
		width: fit-content;
		display: flex;
		flex-direction: column;
		cursor: default;
		.UserSelectNone();

		.saResizeHandle {
			position: absolute;
			height: 0.5rem;
			width: 0.5rem;
			background: @ColorWhite;
			border: 1px solid @ColorPurple600;
			opacity: 0;

			.Hover({
				background: @ColorPurple600;
			});
		}

		.saResizeHandleTop {
			transform: translate(-50%, -50%);
			top: 0;
			left: 50%;
			cursor: ns-resize;
		}

		.saResizeHandleRight {
			transform: translate(50%, -50%);
			top: 50%;
			right: 0;
			cursor: ew-resize;
		}

		.saResizeHandleBottom {
			transform: translate(50%, 50%);
			bottom: 0;
			right: 50%;
			cursor: ns-resize;
		}

		.saResizeHandleLeft {
			transform: translate(-50%, -50%);
			top: 50%;
			left: 0;
			cursor: ew-resize;
		}

		&.saSelected {
			.saResizeHandle {
				opacity: 1;
			}

			.saPlaceholderTitle {
				display: flex;
			}

			.saPlaceholderValue {
				box-shadow: inset 0 0 0 1px @ColorPurple600;
			}
		}

		.saIcon {
			font-size: 2.5rem;
			color: var(--Sa-Color-Icon);
			overflow: hidden;
		}
	}

	.saPlaceholderTitle {
		.FlexCentered();
		width: fit-content;
		background: @ColorPurple600;
		color: @ColorWhite;
		padding: 0.25rem 0.25rem;
		max-height: 1rem;
		font-size: 0.75rem;
		line-height: 0.75rem;
		border-radius: 0.25rem 0.25rem 0 0;
		display: none;
		position: absolute;
		top: -0.9375rem;
		left: 0;
		white-space: nowrap;
	}

	.saPlaceholderValue {
		display: flex;
		box-shadow: inset 0 0 0 1px @ColorPurple400;
		font-size: 0.875rem;
		line-height: 1;
		transition: ease box-shadow .1s;

		&.saNoWidth {
			white-space: nowrap;
		}

		&.saImagePlaceholder {
			.FlexCentered();
			background: @ColorGray150;
			padding: 0;
			height: 100%;
			width: 100%;

			&.saPreserveAspectRatio {
				align-items: flex-end;
				justify-content: flex-start;
				object-fit: contain;
				object-position: left bottom;
			}
		}
	}

	.saPdfTemplateToolbarGroup {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 0.5rem;
	}

	.saToolbarDistribute {
		flex-wrap: wrap;
		padding: 0 0.5rem;
		border-left: 1px solid @ColorGray200;
		border-right: 1px solid @ColorGray200;
	}
}