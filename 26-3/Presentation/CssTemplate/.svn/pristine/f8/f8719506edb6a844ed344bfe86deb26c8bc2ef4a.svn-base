.tox {
	color: var(--Sa-Color-Text) !important;
	font-family: "Lexend", sans-serif !important;
}

.tox-tinymce {
	border: none !important;
	font-family: "Lexend", sans-serif !important;
	border-radius: 0.5rem !important;
}

.tox-tinymce-aux {
	font-family: "Lexend", sans-serif !important;
}

.tox .tox-button {
	font-family: "Lexend", sans-serif !important;
}

.tox .tox-editor-container{
	.tox-menubar,
	.tox-toolbar-overlord,
	.tox-toolbar__group,
	.tox-toolbar__primary,
	.tox-toolbar {
		background-color: transparent;
	}
}

.tox-edit-area > iframe:not(svg):not(rect) {
	border-bottom-right-radius: 0.5rem;
	border-bottom-left-radius: 0.5rem;
	box-shadow: inset 0 0 0 1px var(--Sa-Color-InputFieldBorder);
	transition: ease box-shadow 0.2s;
}

.tox:not(.tox-tinymce-inline) .tox-editor-container .tox-editor-header {
	border-top-right-radius: 0.5rem;
	border-top-left-radius: 0.5rem;
	box-shadow: inset 1px 1px 0 0 var(--Sa-Color-InputFieldBorder), inset -1px 1px 0 0 var(--Sa-Color-InputFieldBorder);
	transition: ease box-shadow 0.2s !important;
}

.saHighlightFieldError {
	.tox-edit-area > iframe:not(svg):not(rect) {
		box-shadow: inset 0 0 0 2px @ColorRed600;
	}

	.tox:not(.tox-tinymce-inline) .tox-editor-container .tox-editor-header {
		box-shadow: inset 1px 1px 0 1px @ColorRed600, inset -1px 1px 0 1px @ColorRed600;
	}
}

.saHighlightFieldWarning {
	.tox-edit-area > iframe:not(svg):not(rect) {
		box-shadow: inset 0 0 0 2px @ColorYellow300;
	}

	.tox:not(.tox-tinymce-inline) .tox-editor-container .tox-editor-header {
		box-shadow: inset 1px 1px 0 1px @ColorYellow300, inset -1px 1px 0 1px @ColorYellow300;
	}
}