.saHelpPage {
	.saHelpMissing {
		color: red;
	}

	.saHelpPageLastUpdated {
		font-size: 0.75rem;
		font-style: italic;
		color: #666666;
	}

	.saHelpPageLinks table {
		border: none;
	}

	.saHelpPageLinks td {
		border: none;
		vertical-align: top;
	}

	.saHelpPageLinks p {
		margin-top: 0 !important;
	}

	* {
		font-family: 'Lexend', sans-serif;
		color: @ColorGray900;
	}

	img {
		max-width: 100%;
		max-height: 100%;

		.saPc & {
			cursor: pointer;
		}
	}

	a {
		font-size: 1rem;
	}

	div.saHelpPageLinks {
		display: inline-block;
	}

	hr {
		background-color: @ColorGray100;
		border: 0;
		height: 1px;
		margin-bottom: 1.25rem;
	}

	ol,
	ul {
		font-size: 1rem;
		line-height: 1.5rem;
		max-width: 40rem;
	}

	p:last-child {
		margin-bottom: 0;
	}

	p~ol,
	p~ul {
		margin-top: -1rem;
	}

	table {
		max-width: 40rem;
		margin-bottom: 1.5rem;
	}
}