.saErrorView {
	display: flex;
	flex-direction: column;
	gap: 2rem;

	.saSmallScreen & {
		padding: 1.5rem;
	}

	.saErrorViewContent {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		overflow-y: auto;

		.saLargeScreen & {
			margin-top: 2.5rem;
		}

		& > .saIcon {
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 1.5rem;
			border-radius: 0.5rem;
			height: 3rem;
			width: 3rem;
			background-color: @ColorGray100;
			color: @ColorGray600;
		}

		.saErrorViewContentInner {
			display: flex;
			flex-direction: column;
			gap: 1.5rem;
			max-height: calc(100vh - 20rem);
			min-height: min-content;

			section {
				display: flex;
				flex-direction: column;

				h2 {
					padding-bottom: 0.25rem;
				}

				h3 {
					font-size: 0.75rem;
					line-height: 0.75rem;
					font-weight: 400;
					color: @ColorGray600;
					margin-bottom: 0.25rem;
					word-break: break-all;
				}

				p {
					font-size: 0.875rem;
					line-height: 1.25rem;
					color: @ColorGray900;
					word-break: break-all;
				}
			}
		}
	}

	.saErrorViewButton {
		.Button();
		.ButtonSizeModeDependent();
		width: fit-content;
		margin-top: 1rem;
	}
}