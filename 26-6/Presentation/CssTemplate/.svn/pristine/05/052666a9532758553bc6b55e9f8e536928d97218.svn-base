.saNotificationsWrapper {
	position: absolute;
	height: 100%;
	animation-duration: 250ms;
	animation-name: drawerslidein;
	animation-timing-function: ease-out;

	&:focus {
		outline: none;
	}

	&.saSlideout {
		animation-duration: 125ms;
		animation-name: drawerslideout;
	}

	.saNotificationsInner {
		display: flex;
		position: absolute;
		top: 0;
		flex-direction: column;
		background: @ColorWhite;
		height: 100%;
		overflow: hidden;
		overflow-y: auto;
		padding: 1rem;
		box-sizing: border-box;
		.BoxShadowSoft();
	}

	.saNotificationList {
		display: flex;
		flex-direction: column;
	}

	.saNotificationsHeading {
		position: sticky;
		top: 0;
		z-index: 2;
		font-weight: 500;
		margin-bottom: -0.25rem;
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		align-items: center;

		&::before {
			content: '';
			position: absolute;
			width: calc(100% + 4rem);
			top: -1.5rem;
			left: -1.5rem;
			height: 4.5rem;
			flex-basis: 100%;
			background: @ColorWhite;
			z-index: -1;
		}

		h3 {
			color: @ColorGray900; //Override from screen.template
		}
	}

	.saCloseModal {
		.Button();
		.IconButtonSizeStandard();
		.ButtonGhost();
		font-size: 1.25rem;

		&::after {
			content: '';
			height: 3.5rem;
			width: 3.5rem;
			position: absolute;
			top: -1rem;
			right: -1rem;
		}
	}

	.saClearAll {
		.Button();
		.ButtonGhost();
		width: fit-content;
		padding: 0.5rem;
		border-radius: 0.5rem;
	}

	.saNotificationWrapper {
		position: relative;
	}

	.saNotification {
		position: relative;
		display: flex;
		flex-direction: column;
		transition: all .2s ease;
		background: @ColorWhite;
		border: 1px solid @ColorGray150;

		&.saActive {
			cursor: pointer;

			.Hover({
				border: 1px solid @ColorBlue600;
				background: @ColorBlue50;

				.saNotificationText {
					color: @ColorBlue600;
				}
			});

			&:active {
				background: @ColorBlue100;
			}
		}
	}

	.saDismissButton {
		position: absolute;
		right: 0;
		top: 0;
		color: @ColorGray600;
		background-color: transparent;
		font-weight: 400;
		transition: all .2s ease;
		width: fit-content;
		cursor: pointer;
		font-size: 0.75rem;
		line-height: 0.75rem;
		padding: 0.25rem 0.375rem;
		border-radius: 0.25rem;
		margin: 0.25rem;

		.Hover({
			color: @ColorRed600;
			background: @ColorRed100;
		});

		&:active {
			color: @ColorWhite;
			background: @ColorRed600;
			border-radius: 0.375rem;
		}
	}

	.saNotificationText {
		color: @ColorGray900;
		word-break: break-word;
	}

	p {
		font-size: 0.875rem;
		line-height: 1rem;
		font-weight: 400;
		color: @ColorGray600;
	}

	.saNotificationExtraText {
		font-weight: 400;
		font-size: 0.75rem;
		color: @ColorGray600;
		margin-bottom: -0.5rem;
	}

	.saNotificationTime {
		font-weight: 400;
		font-size: 0.625rem;
		color: @ColorGray600;
	}
}

.saStandard .saNotificationsWrapper {
	.saNotificationsInner {
		gap: 1rem;
		width: 25rem;
	}

	.saNotificationList {
		gap: 1rem;
	}

	.saClearAll {
		.ButtonSizeCompact();
	}

	.saNotification {
		gap: 0.5rem;
		border-radius: 0.5rem;
		padding: 1rem 3rem 1rem 1rem;
	}

	.saNotificationHeading {
		font-size: 1rem;
	}
}

.saCompact .saNotificationsWrapper {
	.saNotificationsInner {
		gap: 0.5rem;
		width: 25rem;

		.saNotificationsHeading {
			&::before {
				content: '';
				height: 4rem;
			}
		}
	}

	.saNotificationList {
		gap: 0.5rem;
	}

	.saClearAll {
		.ButtonSizeMini();
	}

	.saNotification {
		gap: 0.5rem;
		border-radius: 0.5rem;
		padding: 0.5rem 3rem 0.5rem 0.5rem;
	}

	.saNotificationHeading {
		font-size: 0.75rem;
	}
}

.saSmallScreen,
.saSmallscreensidebar {
	.saNotificationsWrapper {
		position: relative;

		.saNotificationsInner {
			gap: 1rem;
			width: 100%;
			border-left: none;
		}

		.saNotificationList {
			gap: 1rem;
		}

		.saClearAll {
			.ButtonSizeCompact();

			&::after {
				content: '';
				height: 2.75rem;
				width: 100%;
				position: absolute;
				left: 0;
				top: -0.5rem;
			}
		}

		.saDismissButton::after {
			content: '';
			height: 2.75rem;
			width: 100%;
			position: absolute;
			left: 0;
			top: -0.75rem;
		}

		.saNotification {
			gap: 0.5rem;
			border-radius: 0.5rem;
			padding: 1rem 2.5rem 1rem 1rem;
		}

		.saNotificationHeading {
			font-size: 1rem;
		}
	}
}

@keyframes drawerslidein {
	from {
		left: -25rem;
	}

	to {
		left: 0;
	}
}

@keyframes drawerslideout {
	from {
		left: 0;
	}

	to {
		left: -25rem;
	}
}