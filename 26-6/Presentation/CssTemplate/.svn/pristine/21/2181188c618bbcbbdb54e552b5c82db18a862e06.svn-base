.saBankgiroLink {
	min-width: 40rem;

	.saDialog {
		border: 2px solid @ColorGray200;
		border-radius: 0.75rem;
		display: inline-block;
		max-width: 50rem;
		padding: 1rem 3rem 1.5rem 3rem;
		margin-top: 1rem;

		h2 {
			margin-bottom: 0.5rem;
		}

		p {
			margin-bottom: 1rem;
		}

		button {
			display: inline-flex;
		}

		button i {
			margin-right: 0.5rem;
			color: var(--Sa-Color-Icon);
		}

		.saStatus {
			font-size: large;
		}

		.saQrWrapper {
			display: flex;
			justify-content: center;

			img {
				margin-top: 1rem;
			}
		}
	}

	button {
		.Button();
		.ButtonSizeModeDependent();
		min-width: 6rem;
	}

	button:disabled {
		opacity: 0.4;
		pointer-events: none;
	}

	ol {
		margin: 0;
		padding: 0;
		margin-bottom: 1rem;
	}

	ol li {
		padding-left: 2rem;
		list-style-type: decimal;
		list-style-position: inside;
		position: relative;
		z-index: 1;
		font-weight: 600;
		line-height: 2;
		font-size: 1rem;
	}

	ol li ol {
		padding-bottom: 2px;
		margin-bottom: 0;
		margin-top: -2px;
	}

	ol li ol li {
		font-size: 0.75rem;
		font-weight: 400;
		line-height: 1.6;
		padding-bottom: 0;
		padding-left: 2rem;
		list-style-type: none;
		margin-bottom: 0.5rem;
	}

	li:not(.saParent).saError {
		background: @ColorRed50;
		border-radius: 0.5rem;
	}

	ol li .saImgHolder {
		position: absolute;
		width: 2rem;
		height: 100%;
		top: 0;
		left: .5rem;
		z-index: 2;
	}

	ol li ol li .saImgHolder {
		top: 2px;
	}

	ol li.saWaiting span.saImgHolder,
	ol ol li.saNode.saWaiting span.saImgHolder {
		text-decoration: none;
	}

	ol li.saAborted,
	ol ol li.saNode.saAborted span {
		text-decoration: line-through;
	}

	ol li.saAborted span.saImgHolder,
	ol ol li.saNode.saAborted span.saImgHolder {
		text-decoration: none;
	}

	.saStepStatus {
		display: none;
	}

	.saOk > .saImgHolder > .saStepStatus.saOk {
		display: inline-block;
		color: @ColorGreen500;
	}

	.saError > .saImgHolder > .saStepStatus.saError {
		display: inline-block;
		color: @ColorRed600;
	}

	.saOngoing > .saImgHolder > .saStepStatus.saOngoing {
		display: inline-block;
		color: @ColorBlue800;
	}

	.saInfoText {
		font-size: 0.875rem;
		padding: 0 0 0 1.5rem;
		margin-left: .5rem;
		font-weight: 300;
	}

	.saInfoText i {
		font-size: 1.1875rem;
		color: var(--Sa-Color-InfoIndicator);
		margin-right: 0.3125rem;
		top: 2px;
		position: relative;
	}

	.saBankgiroLogotype {
		padding: 0.5rem 0;
	}

	.saErrorBox {
		padding: 0.5rem;
		background: @ColorRed50;
		border: 1px solid @ColorRed600;
		border-radius: 0.5rem;
		margin: 0.75rem 0;
	}

	.saDebugBox {
		background: @ColorGray50;
		border: 1px solid @ColorGray150;
		border-radius: 0.5rem;
		padding: 0.5rem 1rem;
		margin-top: 1.5rem;

		h2,
		p {
			padding-bottom: 0.5rem;
		}

		h2 {
			font-size: 1.5rem;
		}
	}
}