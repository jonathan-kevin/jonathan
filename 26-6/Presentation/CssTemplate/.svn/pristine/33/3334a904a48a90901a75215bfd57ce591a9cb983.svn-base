.saInputTextWrapper {
	&.saHighlightFieldError:not(.saDisabled) {
		.saTextArea {
			outline: 2px solid @ColorRed600;
			outline-offset: -2px;
			box-shadow: none !important;

			.Hover ({
				outline: 2px solid @ColorRed700;
			});

			&:focus-within {
				outline: 2px solid @ColorRed700;
			}
		}
	}

	&.saHighlightFieldWarning:not(.saDisabled) {
		.saTextArea {
			outline: 2px solid @ColorYellow300;
			outline-offset: -2px;
			box-shadow: none !important;

			.Hover ({
				outline: 2px solid @ColorYellow400;
			});

			&:focus-within {
				outline: 2px solid @ColorYellow400;
			}
		}
	}

	.saTextArea {
		height: auto;
		z-index: 2;
		max-width: none;
		cursor: auto;
		outline: 1px solid var(--Sa-Color-InputFieldBorder);
		outline-offset: -1px;
		border: 2px solid transparent;
		box-shadow: none;
		line-height: 1.25rem;
		padding: 0.25rem 0.5rem;

		&:hover,
		&:focus-within {
			outline: 2px solid var(--Sa-Color-Primary600);
			outline-offset: -2px;
			box-shadow: none;
		}

		&:disabled {
			outline: none;
		}

		&::-webkit-resizer {
			background-image: url(../img/resizer.svg);
		}

		&[dir='rtl']::-webkit-resizer {
			background-image: url(../img/resizer-rtl.svg);
		}
	}

	.saCharacterCount {
		font-size: 0.75rem;
		text-align: right;
		margin-right: 2px;
		margin-top: 0.25rem;
		color: var(--Sa-Color-TextSecondary);

		&.saMaxLength span:first-child {
			font-weight: 700;
		}

		&.saShake {
			animation: saShake 0.82s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
		}
	}
}

@keyframes saShake {
	10%,
	90% {
		transform: translate3d(-1px, 0, 0);
	}
	20%,
	80% {
		transform: translate3d(2px, 0, 0);
	}
	30%,
	50%,
	70% {
		transform: translate3d(-0.25rem, 0, 0);
	}
	40%,
	60% {
		transform: translate3d(0.25rem, 0, 0);
	}
}
