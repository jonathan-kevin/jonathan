h1,
h2,
h3,
h4,
h5,
h6 {
	font-family: 'Lexend', Arial, sans-serif;
	color: @ColorGray900;
	margin: 0;
	padding: 0;
	border: 0;
	vertical-align: baseline;
}

h1 {
	font-weight: 600;
	font-size: 2rem;
	line-height: 2.5rem;

	.saCompact & {
		font-size: 1.5rem;
		line-height: 2rem;
	}

	.saSmallScreen & {
		font-size: 1rem;
		line-height: 1.25rem;
	}
}

h2 {
	font-weight: 600;
	font-size: 1.5rem;
	line-height: 2rem;

	.saCompact & {
		font-size: 1.25rem;
		line-height: 1.75rem;
	}

	.saSmallScreen & {
		font-size: 1rem;
		line-height: 1.25rem;
	}
}

h3 {
	font-weight: 500;
	font-size: 1rem;
	line-height: 1.375rem;

	.saSmallScreen & {
		font-size: 0.875rem;
		line-height: 1.25rem;
	}
}

h4 {
	font-weight: 700;
	font-size: 0.875rem;
	line-height: 1.375rem;

	.saSmallScreen & {
		font-size: 0.75rem;
		line-height: 1.125rem;
	}
}

h5 {
	font-weight: 300;
	font-size: 0.75rem;
	line-height: 1.125rem;

	.saSmallScreen & {
		font-size: 0.75rem;
		line-height: 1.125rem;
	}
}

h6 {
	font-weight: 900;
	font-size: 0.75rem;
	line-height: 1.125rem;
	font-variant: small-caps;
}