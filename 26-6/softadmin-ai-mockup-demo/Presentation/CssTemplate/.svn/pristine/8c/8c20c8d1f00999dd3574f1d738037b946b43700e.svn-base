.saBoxTableWrapper {
	overflow-x: auto;
	position: relative;

	.saBoxTable {
		.saTableHeading {
			text-align: left;
			font-size: 0.75rem;
			font-weight: 500;
			color: @ColorGray500;
		}

		.saTableCell {
			height: 1.5rem;
			padding-right: 0.75rem;
			white-space: nowrap;

			&.center {
				text-align: center;
			}

			&.right {
				text-align: right;
			}
		}

		td {
			font-size: 0.875rem;
			color: @ColorGray900;
		}
	}
}