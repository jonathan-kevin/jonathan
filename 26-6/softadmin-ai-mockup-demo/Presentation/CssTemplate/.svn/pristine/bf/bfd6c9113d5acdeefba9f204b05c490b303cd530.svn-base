// Style for NewEdit and ParameterInput.

@keyframes saFieldLabelVisibilityChanged {
	from {
		background-color: var(--Sa-Color-ControlVisibilityChangeBackground);
	}

	to {
		background-color: @ColorWhite;
	}
}

@keyframes saFieldCellVisibilityChanged {
	from {
		background-color: var(--Sa-Color-ControlVisibilityChangeBackground);
	}

	to {
		background-color: @ColorWhite;
	}
}

@keyframes saSectionTarget {
	from {
		background-color: var(--Sa-Color-PrimaryButtonBackgroundActive-Brightness180);
		color: var(--Sa-Color-PrimaryButtonBackgroundActive);
	}
}

// Legend

.saInputPage {
	.saInputPageLegend {
		width: fit-content;
		font-size: 0.875rem;
		margin-bottom: 1rem;

		.saSmallScreen & {
			margin: 1rem 1rem 0 1rem;
		}

		.saToggleDescriptionButton {
			margin-left: 0.5rem;
			margin-right: 0.5rem;
			vertical-align: baseline;
			justify-content: center;
			align-items: center;
			height: 1rem;
			width: 1rem;
			border-radius: 50%;
			padding: 0;
			background: white;
			color: #7088a4;
			font-size: 1rem;
			display: inline-block;
		}
	}
}


// Field groups.
.saInputPage {
	color: @ColorGray900;

	// Generated by web forms. Replaced during client-side construction of the page.
	.saFormPlaceholder {
		display: none;
	}

	// Wraps the form root and the table of contents.
	.saFormRootAndTocWrapper {
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
		justify-content: flex-start;
		align-items: flex-start;
		width: 100%;
		max-width: 100%;
		height: 100%;
		box-sizing: border-box;
		interpolate-size: allow-keywords;

		&.saTocFixed {
			flex-direction: column;
		}
	}

	// All field groups are stored in the form root.
	.saFormRoot {
		display: flex;
		flex: 1;
		flex-direction: column;
		width: 100%;
		min-width: auto;
		order: 1;
	}

	// Wraps anything that could have a border in the old layout. Section wrappers may be nested, so be careful when modifying their style.
	.saSectionWrapper {
		padding-bottom: 1.5rem;
		border-bottom: 1px solid @ColorGray200;
		margin-bottom: 1.5rem;
		width: 100%;

		// Prevent the border from being cut short if the wrapper's contents is wider than the window.
		min-width: min-content;

		&.saLastVisible,
		&.saHiddenControl {
			border: none 0;
			padding-bottom: 0;
			margin-bottom: 0;
		}
	}

	// Around every section header. Omitted in field groups without a head.
	.saSectionHeaderWrapper {
		// Put header above section description.
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		padding-bottom: 0.75rem; // Controls have 0.25rem top padding of their own, for a total padding of 1rem between header and the first control.
		width: 100%;
		max-width: max-content;
		cursor: default;

		&:has(.saCheckbox:not(:checked)),
		&:has(.saClosed) {

			// Don't show description for unchecked heading with checkbox or collapsed heading.
			.saSectionDescription {
				display: none;
			}
		}

		.saStandard & {
			// In standard mode, controls have 0.5rem top padding, for a total padding of 1rem between header and the first control.
			padding-bottom: 0.5rem;
		}
	}

	// Heading, heading with checkbox, collapsible heading.
	.saSectionHeader,
	.saSectionHeader label {
		display: flex;
		flex-direction: row;
		align-items: center;
		background-color: transparent;
		cursor: default;
		overflow-wrap: anywhere;
		color: @ColorGray900;

		// To separate the heading from its checkbox or expander button.
		gap: 1rem;

		.saIcon {
			transition: ease 0.2s transform;
			text-align: center;

			&.saClosed {
				transform: rotate(180deg);
			}
		}
	}

	.saSectionHeader:target,
	.saSectionHeader:target :is(h2, label) {
		animation: saSectionTarget 2s ease-in forwards;
	}

	.saSectionHeader label {
		flex-grow: 1;
		cursor: pointer;
	}

	// Collapsible heading's button.
	.saSectionHeader i {
		width: 1.25rem;
		height: 1.25rem;
		background-color: transparent;
		align-content: center;
		color: @ColorGray500;
		cursor: pointer;
	}

	// Collapsible heading's label. Mirrors <h2>.
	.saSectionHeaderLabel {
		font-weight: 600;
		font-size: 1.5rem;
		line-height: 2rem;

		.saCompact & {
			font-size: 1.25rem;
			line-height: 1.75rem;
		}

		.saSmallScreen & {
			font-size: 1rem;
			line-height: 1.25rem;
		}
	}

	// Collapsible heading.
	button.saSectionHeader {
		cursor: pointer;
		text-align: left;
		transition: ease color 0.2s;
		gap: 0.5rem;

		.Hover({
			color: var(--Sa-Color-PrimaryButtonBackground);

			.saIcon {
				color: currentColor;
			}
		});

		&:active {
			color: var(--Sa-Color-PrimaryButtonBackgroundActive);

			.saIcon {
				color: currentColor;
			}
		}
	}

	.saSectionDescription {
		font-size: 0.875rem;
		line-height: 1rem;
		font-weight: 300;
		max-width: 40rem;
		color: @ColorGray600;
	}

	// Wraps one or more columns of fields.
	.saFieldsRow {
		display: flex;
		flex-direction: row;
		flex-wrap: nowrap;
		width: 100%;
	}

	// Columns of fields.
	.saFieldsColumn {
		display: flex;
		flex-direction: column;
		flex-wrap: wrap;

		.saLargeScreen & {
			width: fit-content;
			padding-right: 2.5rem;
			border-right: 1px solid @ColorGray200;
			margin-right: 2.5rem;
		}

		&.saLastVisible,
		&.saHiddenControl {
			border: none 0;
			padding-right: 0;
			margin-right: 0;
		}

		&:only-child:not(:has(.saMultiColumns)) {
			// Ensure that single-column groups have their bottom border go all the way to the end of the screen.
			width: 100%;
		}
	}
}

// Fields, labels and descriptions.
.saInputPage {

	// Wraps both field and label.
	.saFieldAndLabelWrapper {
		// Don't let the wrapper affect the grid/flex layout.
		display: contents;
	}

	// Wraps a group of fields using right-of.
	.saSiblingRow,
	.saSiblingFields {
		display: contents;
	}

	// This is the field's "cell" in table layout.
	.saFieldCell {
		display: flex;
		flex-direction: column; // Put InfoText under field.
		box-sizing: content-box;
		height: 100%;
	}

	// Wraps the field, its buttons, and any other sibling fields using to-the-right-of.
	.saInput {
		display: flex;
		flex-direction: row;
	}

	// Wraps both the field label and field description. Acts as the label's "cell" in table layout.
	.saLabelCell {
		// Prefer breaking between words, but if a label is a single very long word, break it.
		overflow-wrap: anywhere;
		line-height: 1rem;
		box-sizing: content-box;
		height: 100%;

		// .saCompact & {
		// 	line-height: 1;
		// }

		// Special handling for fields whose name starts with three non-breaking spaces.
		&.saIndentLabel {
			padding-left: 1rem;
		}
	}

	// Field label.
	.saLabel {
		.RestrictedUserHtmlContent();
		.AiIcon();

		// Uses flex and gap because it may contain a button to expand the extended description.
		display: flex;
		flex-direction: row;
		gap: 0.5rem;
		font-weight: 500;
	}

	.saUnsavedParameter {
		color: @ColorRed600;
		border-radius: 0.5rem;

		&:hover {
			color: @ColorRed500;
			background-color: @ColorRed100;
		}
	}

	// Field descriptions and info text.

	.saDescription,
	.saExtendedDescription,
	.saFieldInfoText {
		.RestrictedUserHtmlContent();

		color: var(--Sa-Color-FieldDescription);
		font-size: 0.875rem;
		line-height: 1rem;
		font-weight: 300;
		max-width: 25rem;
		box-sizing: border-box;

		// .saCompact & {
		// 	line-height: 0.875rem;
		// }
	}

	.saExtendedDescription {
		// Slide-down animation on browsers supporting calc-size. The animation is non-critical, so it doesn't need to work on older browsers.
		transition: height ease 0.1s;
		height: auto;
		height: calc-size(auto, size);
		overflow-y: clip;
	}

	.saDescription,
	.saExtendedDescription {
		min-width: 12.5rem;
	}

	.saExtendedDescription {
		padding-left: 0.5rem;
		border-left: 2px solid #2d6ce1;
		margin: 0.5rem 0;
	}

	.saLabelCell:not(.saOpen) .saExtendedDescription {
		visibility: hidden;
		height: 0 !important;
		margin: 0 !important;

		* {
			height: 0 !important;
			margin-top: 0 !important;
			margin-bottom: 0 !important;
			padding-top: 0 !important;
			padding-bottom: 0 !important;
		}
	}

	.saFieldInfoText {
		margin-top: 0.5rem;

		// Using the full 25rem causes medium-long fields to be too jumpy when changing info text.
		max-width: 24rem;
	}

	.saFieldInfoText:empty {
		display: none;
	}

	// Toggle for extended description.
	.saLabelButton.saToggleDescriptionButton {
		background: white;
		color: @ColorGray500;
		font-size: 1rem;

		& .saIcon {
			color: inherit;
			font-size: 1rem;
		}

		&:hover {
			color: @ColorBlue700;
		}

		&:active {
			color: @ColorBlue800;
		}

		&.saOpen {
			color: @ColorBlue600;
		}

		&::after {
			content: '';
			position: absolute;
			height: 2rem;
			width: 2rem;
			bottom: 50%;
			left: 50%;
			transform: translate(-50%, 50%);
		}
	}

	// Toggle for multirow description.
	.saLabelButton.saMultiRowDescriptionButton {
		background: white;
	}

	// Wraps the JavaScript buttons.
	.saJavaScriptButtons {
		display: flex;
		flex-direction: row;
		gap: 0.5rem;
		margin-right: 1.5rem;
	}

	// Marker class for controls that belong to the input page.
	// This class is applied to each field and parameter, but not to fields in multirows.
	.saInputPageField {
		// Ensure margin between the control and its buttons/siblings.
		margin-right: 1rem;
	}

	.saSmallScreen & .saInputPageField {
		// In small screen mode controls are placed vertically.
		margin-right: 0;
	}
}

// Special handling of certain elements in descriptions.
.saInputPage {

	.saSectionDescription,
	.saDescription,
	.saExtendedDescription,
	.saFieldInfoText {

		// Since we reduce the font weight, allowing bold to use its default weight of 700 makes it look out-of-place.
		b,
		strong {
			font-weight: 500;
		}

		code {
			font-family: @CodeFont;
			color: @ColorGray900;
			background-color: @ColorGray50;
			outline: 1px solid @ColorGray200;
			border-radius: 0.25rem;
			padding: 2px 0.25rem;
			font-size: smaller;
		}
	}
}


// Visibility JavaScript support.
.saInputPage {
	.saLargeScreen & .saHighlightFieldVisibilityChange {
		&.saLabelCell {
			animation: saFieldLabelVisibilityChanged 1s cubic-bezier(1, 0, 0.8, 1);
		}

		&.saFieldCell {
			animation: saFieldCellVisibilityChanged 1s cubic-bezier(1, 0, 0.8, 1);
		}
	}

	// Controls hidden by scripts, not the Hidden control type. Applied not just to the control itself, but also its label and other layout elements connected to it.
	.saHiddenControl {
		// We use visibility:hidden instead of display:none to make the input page's layout less jumpy.
		visibility: hidden !important;
		height: 0 !important;
		max-height: 0 !important;
		min-height: 0 !important;
		margin-top: 0 !important;
		margin-bottom: 0 !important;
		padding-top: 0 !important;
		padding-bottom: 0 !important;

		* {
			visibility: hidden !important;
			height: 0 !important;
			margin-top: 0 !important;
			margin-bottom: 0 !important;
			padding-top: 0 !important;
			padding-bottom: 0 !important;
		}

		&.saSectionWrapper {
			display: none;
		}

		&.saHiddenPermanently {
			// Controls that are unable to become visible should not reserve space.
			// This is mostly a problem when a hidden field has a very long column name.
			width: 0 !important;
		}
	}
}

// Control widths.
.saLargeScreen .saInputPageField,
.saMultiRowWrapper .saMultiRowField {
	&.shortest {
		width: @FieldWidthShortest;
	}

	&.short {
		width: @FieldWidthShort;
	}

	&.mediumShort {
		width: @FieldWidthMediumShort;
	}

	&.mediumLong {
		width: @FieldWidthMediumLong;
	}

	&.long {
		width: @FieldWidthLong;
	}

	&.longest {
		width: @FieldWidthLongest;
	}
}

.saLargeScreen .saInputWrapper,
.saLargeScreen .saMultiRowCell .saMultiRowInputWrapper {

	&.shortest .saValidationMessage {
		width: @FieldWidthShortest;
	}

	&.short .saValidationMessage {
		width: @FieldWidthShort;
	}

	&.mediumShort .saValidationMessage {
		width: @FieldWidthMediumShort;
	}

	&.mediumLong .saValidationMessage {
		width: @FieldWidthMediumLong;
	}

	&.long .saValidationMessage {
		width: @FieldWidthLong;
	}

	&.longest .saValidationMessage {
		width: @FieldWidthLongest;
	}
}

.saLargeScreen .saMultiRowCell .saMultiRowInputWrapper {
	&.saMediumShortValidation .saValidationMessage {
		width: @FieldWidthMediumShort;
	}
}

.saLargeScreen .saSiblingFields .saFieldCell:not(:last-child) {
	& .saInputWrapper.saMediumShortValidation .saValidationMessage {
		width: @FieldWidthMediumShort;
	}
}

// Only include style critical for row layout here. Avoid adding borders, colors, or any other visual styling.
.saLargeScreen .saLabelsBefore {
	.saFieldCollection {
		display: grid;
		// Use min-content for labels max-content for control to prevent excess whitespace from being distributed equally between them. We never want to add excess whitespace to the label.
		grid-template-columns: minmax(min-content, max-content) auto;
		grid-template-rows: auto;
		align-items: start;
		height: min-content;
		width: 100%;

		.saLabelCell,
		.saFieldCell {
			padding-top: 0.5rem;
			padding-bottom: 0.5rem;

			.saCompact& {
				// Using padding 4 above and below ensures that there are 0.5rem between fields, and that the background-color used for visibility change indicator is centered around the control.
				padding-top: 0.25rem;
				padding-bottom: 0.25rem;
			}
		}

		.saLabelCell {
			// Allowing labels to grow too large puts checkboxes and other controls too far from their label, if another control on the page has a long label or description, and the checkbox has a short label.
			max-width: 15.5rem;

			// Need a min-width or labels are line-broken too aggressively in a multi-column layout. We'd rather have a scrollbar than squash the labels into unreadability to fit on screen.
			min-width: 6rem;

			.saLabel {
				// Labels without a description underneath get padding to make them look more centered.
				padding-top: 0.5rem;

				display: inline-block;
			}

			.saLabelButton.saToggleDescriptionButton,
			.saAiIcon {
				display: inline-block;
				margin-left: 0.5rem;
				vertical-align: top;
			}

			.saLabel:has(+ .saDescription) {
				padding-top: 1px;
				padding-bottom: 1px;
			}
		}

		.saFieldCell {
			// Separate input fields from their label. We can't use gap on the container because we want to use visibility:hidden for hidden fields instead of display:none.
			padding-left: 0.5rem;

			.saStandard& {
				padding-left: 1.5rem;
			}

			&.saFieldCellWithoutLabel {
				grid-column: span 2;
				padding-left: 0;
			}
		}

		.saSiblingFields {
			display: flex;

			.saLabelCell {
				margin-left: 1rem;

				// Right-of-labels can be very narrow (for example, a label might be just a dash. Therefore we don't want to give them a min width.
				// Since we don't set a min width, we also can't let them break anywhere, or they may degrade into having one letter per line.
				min-width: unset;
				overflow-wrap: break-word;
			}
		}

		&:not(.saMultiColumns) .saFieldCell.saFieldCellWithoutLabel:has(.saMultiRow) {
			// Prevent multi-rows using col span from causing excessive whitespace between other field labels and their controls in the same fieldset.
			width: 0;
		}

		// Multi column fields where the tab order is left to right, top to bottom.
		each(range(2, 19), {
			&.sa@{value}Columns {
				// The first column is label, the second is control, and the third is 1rem padding to fake a gap.
				grid-template-columns: repeat(@value, minmax(min-content, max-content) auto 1rem);

				// If we allow the table to have a width of 100% then columns will be too far from each other.
				width: auto;
			}
		});

}
}

// Only include style critical for column layout here. Avoid adding borders, colors, or any other visual styling.
.saLargeScreen .saLabelsAbove {
	.saFieldCollection {
		display: flex;
		flex-direction: column;

		// Multi column fields where the tab order is left to right, top to bottom.
		each(range(2, 19), {
			&.sa@{value}Columns {
				display: grid;

				// The first column is the wrapper, the second is padding to fake a gap.
				grid-template-columns: repeat(@value, auto 1rem);
			}
		});

		// Treat the label and the field as one item in the grid.
		&.saMultiColumns .saFieldAndLabelWrapper:not(.saCheckboxFieldAndLabelWrapper) {
			display: flex;
			flex-direction: column;

			.saLabelCell {
				// Stop the lable from creating a gap between it and the input field
				// when field validation is present.
				height: unset
			}
		}
	}

	.saFieldCollection {
		&.longest .saLabelCell {

			.saDescription,
			.saExtendedDescription {
				max-width: @FieldWidthLongest;
			}
		}
	}

	.saSiblingRow {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(0, auto));
		grid-template-rows: repeat(2, auto);
		grid-auto-flow: column;
	}

	.saLabelCell {
		max-width: max-content;

		// Reserve some margin between the labels, for when using right-of and field labels are longer than their controls.
		margin-right: 1rem;
	}

	.saFieldCell {
		padding-top: 0.5rem;
		padding-bottom: 1.5rem;

		.saCompact& {
			padding-bottom: 1.25rem;
		}
	}

	.saCheckboxFieldAndLabelWrapper {
		display: flex;
		gap: 0.5rem;

		.saInputWrapper {
			max-width: 1.25rem;
		}

		.saLabelCell {
			padding-top: 0.1875rem;
			order: 2;
			margin-bottom: 0.5rem;

			&:has(.saDescription) {
				padding-top: 0;
			}
		}

		.saFieldCell {
			order: 1;
			padding-top: 0;
		}

		.saCheckboxControl {
			padding: 0;
			margin: 0;
		}

		.saExtendedDescription {
			position: relative;
			left: -1.75rem;
		}
	}

	.saSectionWrapper:not(.saLastVisible) {
		// Reduce bottom-padding on the wrapper to compensate because fields have their own bottom padding.
		// This makes the border used as separator look centered.
		padding-bottom: 0.5rem;
	}
}

// All small screen style.
.saSmallScreen {
	.saInputPage {
		display: flex;
		flex-direction: column;
		flex-grow: 1;
		justify-content: space-between;
	}

	.saFormRoot {
		padding: 1rem;
	}

	.saJavaScriptButtons {
		margin-right: 0;
	}

	.saSectionWrapper {
		max-width: 100%;
	}

	.saFieldCollection {
		display: flex;
		flex-direction: column;
		width: 100%;
	}

	.saFieldsRow {
		flex-direction: column;
	}

	// Put separators between columns that have their own headings.
	// If the saSectionWrapper class is on a fieldset element instead of a div then the columns share header, and should not have a separator.
	div.saSectionWrapper .saFieldsColumn:not(.saLastVisible) {
		padding-bottom: 1.5rem;
		border-bottom: 1px solid @ColorGray200;
		margin-bottom: 1.5rem;
	}

	// Hack to put the checkboxes label to the right.
	.saCheckboxFieldAndLabelWrapper {
		display: flex;

		.saLabelCell {
			padding-top: 0.1875rem;
			padding-left: 0.5rem;
			order: 2;
		}

		.saFieldCell {
			order: 1;
		}

		.saInputWrapper {
			max-width: 1.25rem;
		}
	}

	.saLabelCell {
		padding-bottom: 0.5rem;
	}

	.saDescription,
	.saExtendedDescription {
		max-width: unset;
	}

	.saFieldCell {
		padding-bottom: 1.5rem;
	}

	.saInput {
		width: 100%;
		flex-direction: column;
	}

	.saJavaScriptButtons {
		display: flex;
		flex-wrap: wrap;
		margin-top: 0.5rem;
		max-width: calc(100vw - 2rem); //100% width of screen minus 1rem padding on each side.

		// Put extra distance between the buttons and the next field, to make it clearer that they are not related.
		margin-bottom: 0.5rem;

		button {
			// Have the buttons grow to use all available space on the row.
			max-width: 100%;
			flex-grow: 1;
		}
	}
}

// The form buttons.
.saInputPageFooter {
	background: @ColorWhite;
	padding: 0.5rem 0;
	z-index: 5;

	.saLargeScreen & {
		margin-top: 0.5rem;
	}

	// If the user zooms in too much then we can't allow sticky buttons as they would cover the form fields.
	@media (min-height: 500px) {

		// For search forms, the form buttons should always be visible so that the user can click them without filling in all search parameters.	// On the other hand, for edit forms the buttons should be after the last form field, to increase the chance that the user actually fills in the form properly.
		&.saSearchFormFooter {
			position: sticky;
			bottom: 0;
		}
	}

	.saFormButtonGroup {
		.saSmallScreen & {
			box-sizing: border-box;
			padding: 0.5rem;
			flex-direction: row;
			flex-wrap: wrap;
			width: 100%;

			&:has(:nth-child(2):last-child) .saFormButton {
				flex: 1 1 48%;
			}
		}
	}

	.saFormButton {
		.Button();
		.ButtonSizeModeDependent();
		overflow: hidden;
		padding-right: 2rem !important;

		.saSmallScreen & {
			flex: 1 0 100%;
			min-width: fit-content;
			white-space: unset;
			text-overflow: unset;
		}

		.saCompact & {
			padding: 0.5rem;
			padding-right: 2rem;
			height: 2rem;
		}
	}
}