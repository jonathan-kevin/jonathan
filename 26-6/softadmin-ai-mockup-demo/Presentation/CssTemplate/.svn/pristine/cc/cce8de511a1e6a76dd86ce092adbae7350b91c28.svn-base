.saPagination {
	font-size: 0.875rem;
	display: flex;
	align-items: center;
	justify-content: center;

	button {
		.Button();
		.ButtonGhost();
		.IconButtonSizeCompact();

		&:disabled {
			background: transparent;

			.saIcon {
				color: @ColorGray200;
			}
		}
	}

	input {
		max-width: 2rem;
		height: 1.75rem;
		padding: 2px;
		text-align: center;
		border-radius: 0.5rem;
		min-width: 2rem;
		background: @ColorWhite;
		font: inherit;
		color: inherit;
		border: 1px solid @ColorGray200;
		transition: all 0.2s ease;
		width: 100%;
	}

	.saPaginationPages {
		display: flex;
		align-items: baseline;
		justify-content: center;
		gap: 0.5rem;
		padding: 0 0.5rem;
		white-space: nowrap;
		word-break: keep-all;
	}
}

.saSmallScreen .saPagination {
	box-sizing: border-box;
	position: sticky;
	left: 0;
	bottom: 0;
	max-width: 100vw;
	background: @ColorWhite;
	z-index: 2;
	height: 3rem;
	border-top: 1px solid @ColorGray200;
	margin-top: 1rem;

	button {
		min-width: 3rem;
		height: 3rem;
	}
}

.saSmallScreen .saListGrid .saPagination {
	margin-top: 0;
}

.saSmallScreen .saGridWrapper .saPagination {
	margin-left: -1rem;
}

.saSmallScreen .saMultiPartContent .saGridWrapper .saPagination {
	max-width: calc(100vw - 4rem);
}