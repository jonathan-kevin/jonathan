.saInputCardsWrapper {
	display: flex;
	width: 100%;
	box-sizing: border-box;
	padding-right: 1rem;
	.RadioButton();

	* {
		box-sizing: border-box;
	}

	.saSmallScreen & {
		padding-right: 0;
	}

	legend + & {
		padding-top: 0.5rem;
	}

	&.saHighlightFieldError {
		label.saInputCardWrapper:has(:checked):has(:enabled),
		&.saEmpty label.saInputCardWrapper:has(:enabled) {
			&.saLarge {
				.saInputCardHeading {
					background-color: @ColorRed50;
					box-shadow: inset 0 0 0 1px @ColorRed600;
					color: @ColorRed700;
				}

				.saInputCardBody {
					box-shadow: inset 1px -1px 0 0 @ColorRed600, inset -1px -1px 0 0 @ColorRed600;
				}
			}

			&.saNoHeading {
				background-color: @ColorRed50;
				color: @ColorRed700;
				box-shadow: inset 0 0 0 2px @ColorRed600;

				.saInputCardHeading,
				.saInputCardDescription,
				.saInputCardIconWrapper .saIcon {
					color: @ColorRed700;
				}
			}

			input.saRadio:checked {
				.RadioButtonErrorHover();
			}
		}
	}

	&.saHighlightFieldWarning {
		label.saInputCardWrapper:has(:checked):has(:enabled) {
			&.saLarge {
				.saInputCardHeading {
					background-color: @ColorYellow50;
					box-shadow: inset 0 0 0 1px @ColorYellow300;
					color: @ColorYellow600;
				}

				.saInputCardBody {
					box-shadow: inset 1px -1px 0 0 @ColorYellow300, inset -1px -1px 0 0 @ColorYellow300;
				}
			}

			&.saNoHeading {
				background-color: @ColorYellow50;
				color: @ColorYellow600;
				box-shadow: inset 0 0 0 2px @ColorYellow300;

				.saInputCardHeading,
				.saInputCardDescription,
				.saInputCardIconWrapper .saIcon {
					color: @ColorYellow600;
				}
			}

			input.saRadio:checked {
				.RadioButtonWarningHover();
			}
		}
	}
}

.saInputCards {
	display: flex;
	gap: 0.5rem;
	flex-direction: row;
	flex-wrap: wrap;
	height: fit-content;
	grid-auto-rows: 1fr;
	width: 100%;

	.saLargeScreen & {
		min-width: 15.5rem;
	}

	&.saSmall {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(7rem, 1fr));
	}

	&.saMedium {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(10.5rem, 1fr));
	}
}

.saInputCardWrapper {
	display: flex;
	flex-direction: column;
	user-select: none;
	cursor: pointer;
	position: relative;
	box-sizing: border-box;
	transition: ease box-shadow 0.2s, ease border-radius 0.2s, ease color 0.2s,
		ease background 0.2s;
	color: @ColorGray900;

	.saInputCardHeading {
		display: flex;
		gap: 0.5rem;
		align-items: center;
		font-size: 1rem;
		line-height: 1rem;
		font-weight: 500;
		transition: inherit;
		box-sizing: border-box;
		overflow-wrap: anywhere;
		flex-wrap: wrap;
		flex-shrink: 0;

		.saMedium&,
		.saSmall& {
			font-size: 0.875rem;
			text-align: center;
		}
	}

	&.saNoHeading {
		border-radius: 0.5rem;
		padding: 1rem 0.5rem;
		gap: 0.5rem;
		overflow: unset;
		justify-content: start;
		background-color: @ColorWhite;
		box-shadow: inset 0 0 0 1px var(--Sa-Color-InputFieldBorder);
		transition: ease box-shadow 0.2s, ease border-radius 0.2s,
			ease background 0.2s;

		input {
			height: 100%;
			width: 100%;
			background-color: transparent;
			border: none;
			box-shadow: none;
			inset: 0;
			border-radius: 0;
			appearance: none;
			position: absolute;
			padding: 0;
			padding-block: 0;
			padding-inline: 0;
			display: flex;
			border-radius: 0.5rem;
			pointer-events: none;
		}
	}

	.saInputCardBody {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 1rem;
		height: 100%;
		transition: inherit;

		.saNoHeading& {
			align-items: center;
			gap: 0.25rem;
			padding: 0;
			height: fit-content;
		}
	}

	.saInputCardDescription {
		font-size: 0.75rem;
		font-weight: 400;
		color: @ColorGray600;
		width: 100%;
		overflow-wrap: break-word;

		.saNoHeading& {
			text-align: center;
		}
	}

	.saInputCardIconWrapper {
		.FlexCentered();

		.saNoHeading& {
			font-size: 1.5rem;

			img {
				height: 2rem;
			}
		}
	}

	&.saLarge {
		overflow: hidden;
		width: 19rem;

		.saInputCardHeading {
			min-height: 2.5rem;
			overflow: hidden;
			background-color: @ColorGray100;
			padding: 0.5rem 2.5rem 0.5rem 1rem;
			border-top-left-radius: 0.5rem;
			border-top-right-radius: 0.5rem;
			box-shadow: inset 0 0 0 1px var(--Sa-Color-InputFieldBorder);
		}

		&.saNoBody .saInputCardHeading {
			border-radius: 0.5rem;
		}

		.saInputCardBody {
			background-color: white;
			border-bottom-left-radius: 0.5rem;
			border-bottom-right-radius: 0.5rem;
			box-shadow: inset 1px -1px 0 0 var(--Sa-Color-InputFieldBorder), inset -1px -1px 0 0 var(--Sa-Color-InputFieldBorder);
		}

		&.saActive {
			.Hover({
				.saInputCardHeading {
					box-shadow: inset 0 0 0 1px @ColorBlue600;
					background-color: @ColorBlue50;
					color: @ColorBlue600;
					border-bottom-color: @ColorBlue600;
				}

				.saInputCardBody{
					box-shadow: inset 1px -1px 0 0 @ColorBlue600, inset -1px -1px 0 0 @ColorBlue600;
				}
			});
		}

		&.saActive:active {
			.saInputCardHeading {
				border-top-right-radius: 1rem;
				border-top-left-radius: 1rem;
				box-shadow: inset 0 0 0 1px @ColorBlue600;
				background-color: @ColorBlue200;
				color: @ColorBlue700;
				border-bottom-color: @ColorBlue600;

			}

			.saInputCardBody {
				border-bottom-right-radius: 1rem;
				border-bottom-left-radius: 1rem;
				box-shadow: inset 1px -1px 0 0 @ColorBlue600, inset -1px -1px 0 0 @ColorBlue600;
			}

			&.saNoBody .saInputCardHeading {
				border-radius: 1rem;
			}
		}

		&:has(:checked):has(:enabled):not(:active) {
			.saInputCardHeading {
				box-shadow: inset 0 0 0 1px @ColorBlue600;
				background-color: @ColorBlue100;
				border-bottom-color: @ColorBlue600;
			}

			.saInputCardBody{
				box-shadow: inset 1px -1px 0 0 @ColorBlue600, inset -1px -1px 0 0 @ColorBlue600;
			}
		}

		.saInputCardIconWrapper {
			.saLarge& {
				max-height: 10rem;
				font-size: 3rem;
				width: 100%;
				height: 100%;

				img {
					width: 100%;
					height: 100%;
				}
			}
		}
	}

	&.saMedium,
	&.saSmall {
		.saInputCardHeading {
			font-size: 0.875rem;
			text-align: center;
			hyphens: auto;
		}

		&.saActive {
			.Hover({
				background-color: @ColorBlue50;
				color: @ColorBlue600;
				box-shadow: inset 0 0 0 1px @ColorBlue600;

				.saInputCardDescription,
				.saInputCardIconWrapper .saIcon {
					color: @ColorBlue600;
				}
			});
		}

		&.saActive:active {
			background-color: @ColorBlue50;
			color: @ColorBlue600;
			box-shadow: inset 0 0 0 1px @ColorBlue600;

			.saInputCardDescription,
			.saInputCardIconWrapper .saIcon {
				color: @ColorBlue600;
			}
		}

		&.saActive:active {
			border-radius: 1rem;
		}
	}

	&:has(:checked):has(:enabled):not(:active) {
		&.saNoHeading {
			box-shadow: inset 0 0 0 2px @ColorBlue600;
			background-color: @ColorBlue100;
			color: @ColorBlue700;

			.saInputCardDescription,
			.saInputCardIconWrapper .saIcon {
				color: @ColorBlue700;
			}
		}
	}

	.saSmallScreen &.saLarge {
		width: 100%;
	}

	.saDisabled &,
	&.saDisabled {
		cursor: default;

		&.saMedium, &.saSmall,
		&.saLarge .saInputCardBody {
			background-color: @ColorGray100;
		}

		.saInputCardHeading {
			color: @ColorGray500;
			border-bottom-color: @ColorGray200;
		}

		&.saLarge .saInputCardHeading {
			background-color: @ColorGray150;
		}

		img,
		.saIcon {
			opacity: 0.5;
		}

		.saPill {
			background: @ColorGray100 !important;
			color: @ColorGray300;
			cursor: default;
		}
	}

	.saPill {
		.Pill();
		height: unset;
		position: relative;
		background-color: @ColorGray900;
		color: @ColorWhite;
	}

	input.saRadio,
	input.saCheckbox {
		position: absolute;
		top: 0.625rem;
		right: 0.625rem;
	}
}