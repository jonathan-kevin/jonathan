.saGroupView {
	display: flex;
	flex-direction: column;
	gap: 2.5rem;

	.saSmallScreen & {
		gap: 0;
		padding-top: 1.5rem;
	}

	.saEmptyState {
		max-width: 35rem;
		display: none;

		.saLink {
			.Link();
		}
	}

	.saGroupViewWarning:empty {
		display: none;
	}

	.saPillGroup {
		display: flex;
		flex-direction: row;
		align-items: baseline;
		flex-wrap: wrap;
		gap: 0.5rem;

		.saPill {
			.Pill();
			position: relative;
			padding: 0 0.75rem;
			border-radius: 1rem;
			font-weight: 400;
			width: fit-content;
			min-width: 4rem;
			height: 2rem;
			font-size: 0.875rem;
			gap: 0.5rem;
			cursor: pointer;

			&.saActive {
				.PillHover();
			}

			&.saSelected {
				background-color: var(--Sa-Color-Primary600);
				color: @ColorWhite;
			}

			&.saDisabled {
				cursor: not-allowed;
			}

			&::before {
				content: '';
				height: 2.75rem;
				width: 100%;
				background-color: transparent;
				opacity: 0;
				position: absolute;
			}

			input {
				.AppearanceNone();
				border: none;
				margin: 0;
				padding: 0;
				padding-block: 0;
				padding-inline: 0;
				position: absolute;
				height: 100%;
				width: 100%;
				left: 0;
				top: 0;
				background: none;
				border-radius: 1rem;
				cursor: inherit;
			}
		}
	}

	&.saEmpty .saEmptyState {
		display: flex;
	}

	.saGroupViewSearchWrapper {
		display: flex;
		flex-direction: column;
		gap: 1rem;

		.saSmallScreen & {
			padding: 0 1rem;
		}
	}

	.saGroupViewSearchBox {
		border-radius: 0.75rem;
		position: relative;
		max-width: 35rem;

		.saSmallScreen & {
			max-width: 100%;
		}

		.Hover({
			input {
				box-shadow: inset 0 0 0 2px var(--Sa-Color-Primary600);
			}
		});

		input {
			.AppearanceNone();
			font-family: 'Lexend', sans-serif;
			color: var(--Sa-Color-Text);
			background: @ColorWhite;
			font-size: 1rem;
			height: 3.5rem;
			width: 100%;
			padding: 0 2px 0 3.5rem;
			border-radius: 0.75rem;
			border: none;
			box-shadow: inset 0 0 0 1px var(--Sa-Color-InputFieldBorder);
			transition: ease color .2s, ease background .2s, ease box-shadow .2s;

			&::-webkit-search-cancel-button {
				height: 3rem;
				width: 3rem;
				margin-right: 1rem;
				cursor: pointer;
			}

			&::placeholder {
				color: @ColorGray500;
			}

			&:focus {
				box-shadow: inset 0 0 0 2px var(--Sa-Color-Primary600);
			}

			&:focus-within {
				box-shadow: inset 0 0 0 2px var(--Sa-Color-Primary600);
				outline: none;
			}
		}

		button {
			font-size: 1.25rem;
			color: var(--Sa-Color-Icon);
			height: 3rem;
			width: 3rem;
			position: absolute;
			top: 0.25rem;
			padding-block: 0;
			padding-inline: 0;
			border-width: 0;
			border: none;
			background: transparent;
			cursor: pointer;
			border-radius: 0.625rem;
			transition: ease color .2s, ease background .2s, ease border-radius .2s;

			.saSpinIcon {
				display: none;
			}

			&.saSearching {
				.saSearchIcon {
					display: none;
				}

				.saSpinIcon {
					.FlexCentered();
				}
			}

			&:first-child {
				left: 0.25rem;
			}

			&:last-child {
				right: 0.25rem;
			}

			.Hover({
				color: var(--Sa-Color-Primary600);
				background: var(--Sa-Color-Primary100);
			});

			&:active {
				color: var(--Sa-Color-Primary600);
				border-radius: 1rem;
			}
		}
	}

	.saGroupViewButton {
		.Button();
		.ButtonSizeModeDependent();
		.ButtonSecondary();
		width: fit-content;

		.saSmallScreen & {
			width: calc(100% - 2rem);
			margin: 1rem;
		}
	}

	mark {
		background-color: @ColorPurple200;
		color: @ColorPurple900;
		font-weight: 600;
	}

	.saGroupViewGroupWrapper {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;

		.saSmallScreen & {
			gap: 1.5rem;
		}

		.saLargeScreen & {
			padding-bottom: 1rem;
		}
	}

	.saGroupViewGroup {
		display: flex;
		flex-direction: column;
		align-items: center;
		width: fit-content;

		.saGroupViewTitle {
			.GridTop();
			display: flex;
			flex-direction: row;
			gap: 0.5rem;
			width: 100%;
			max-height: 4rem;

			.saCompact & {
				max-height: 2.5rem;
				padding: 0.5rem 0.75rem;

				h2 {
					font-size: 1rem;
					line-height: 1.5rem;
				}
			}
		}

		.saGridTop {
			padding-top: 0;
		}
	}

	.saGroupViewWrapper {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		width: fit-content;

		.saSmallScreen & {
			width: 100%;

			.saRowBody {
				display: none;
			}

			.saOpen .saRowBody {
				display: flex;
			}
		}
	}

	.saGroupViewTable {
		.GridTable();
		border-top: none;
		color: var(--Sa-Color-Text);
		border-radius: 0 0 1rem 1rem;
		border-spacing: 0;
		min-width: 15rem;

		thead {
			position: sticky;
			top: 0;
			z-index: 2;
		}

		th {
			.GridColumnHeader();
			height: 2rem;
			padding: 0 0.5rem;
			vertical-align: middle;

			&:last-child {
				border-right: none;
			}

			.saStandard & {
				height: 3rem;
				padding: 0 1.5rem;
			}

			.saInfoIndicator {
				margin-left: 0.375rem;
			}
		}

		tr {
			background: @ColorWhite;
			height: 3rem;

			.saCompact & {
				height: 2rem;
			}

			&:hover {
				background: var(--Sa-Color-GridRowHighlight);
			}

			&:first-child td {
				border-top: none;
			}

			&:last-child {
				border-radius: 0 0 1rem 1rem;

				td {
					&:first-child {
						border-radius: 0 0 0 1rem;
					}

					&:last-child {
						border-radius: 0 0 1rem 0;
					}

					&:only-child {
						border-radius: 0 0 1rem 1rem;
					}
				}
			}
		}

		td {
			.GridCell();
			padding: 0.5rem 0.5rem;
			position: relative;

			.saStandard & {
				padding: 0.5rem 1.5rem;
			}

			.saCompact & {
				padding: 0.25rem 0.5rem;
			}

			a {
				color: var(--Sa-Color-Link);
				display: block;
				cursor: pointer;

				&::after {
					content: '';
					height: 100%;
					width: 100%;
					left: 0;
					top: 0;
					position: absolute;
				}

				.Hover({
					text-decoration: underline;
				});
			}

			.saCellWrapper {
				gap: 0.375rem;

				.saIconWrapper {
					width: 1.25rem;
					text-align: center;

					.saSystemIcon {
						font-size: 1rem;
					}
				}
			}
		}
	}

	.saListGrid .saCellWrapper,
	.saGroupViewTable .saCellWrapper {
		display: flex;
		align-items: center;
	}
}