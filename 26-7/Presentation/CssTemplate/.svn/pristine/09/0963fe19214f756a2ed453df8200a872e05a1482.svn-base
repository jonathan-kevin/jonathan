@TabHeaderPadding: 1rem;
@TabContentPadding: 0.3125rem;
@TabPadding: 1rem;

.saMultiPartContent .saIFrameTabs .saTabViewInner {
	margin-right: 0;
}

.TabGroup() {
	.saTabGroup {
		display: flex;
		position: relative;
		flex-direction: row;
		align-self: flex-start;
		flex: 1;
		width: 100%;
		z-index: 2;

		* {
			box-sizing: border-box;
		}

		a {
			text-decoration: none;

			&>span:first-child {
				display: flex;
				align-items: center;
				justify-content: center;
			}
		}

		&::after {
			content: '';
			height: 1px;
			width: 100%;
			background: @ColorGray200;
			position: absolute;
			right: 0;
			bottom: 0;
			z-index: -1;
		}
	}

	.saTabGroup>div {
		display: flex;
	}

	.saTabGroup div {

		&:first-child .saTab {
			border-left: 1px solid @ColorGray200;
			border-radius: 0.25rem 0 0 0;
		}

		&:last-child .saTab {
			border-radius: 0 0.25rem 0 0;
		}

		&:only-child .saTab {
			border-radius: 0.25rem 0.25rem 0 0;
		}
	}

	.saTab {
		display: flex;
		position: relative;
		align-items: center;
		justify-content: center;
		text-decoration: none;
		color: var(--Sa-Color-Label);
		background: @ColorGray50;
		border-color: @ColorGray100;
		z-index: 0;
		border: 1px solid @ColorGray200;
		border-left: none;
		font-size: 0.875rem;
		padding: 0 1rem;
		height: 2.5rem;
		max-width: 32ch;
		gap: 0.5rem;
		.StandardTransition();

		.saCompact & {
			padding: 0 0.5rem;
		}

		.Hover({
			color: var(--Sa-Color-LabelHover);
			background-color: @ColorWhite;

			.saIcon {
				color: var(--Sa-Color-IconHover);
			}
		});

		&:active {
			color: var(--Sa-Color-LabelHover);
			background-color: var(--Sa-Color-MenuLinkActive);

			.saIcon {
				color: var(--Sa-Color-IconHover);
			}
		}

		&.saSelected {
			color: var(--Sa-Color-LabelHover);
			background: @ColorWhite;
			border-bottom: 1px solid @ColorWhite;

			.saIcon {
				color: var(--Sa-Color-IconHover);
			}
		}
	}

	.saTabText {
		.Ellipsis();
		min-width: 0;
		line-height: 1.125rem;
		font-size: 0.875rem;
	}

	.saTab .saIcon {
		color: @ColorGray600;
		transition: ease all .2s;
	}

	.BadgeCount();

	.saTabGroup .saTab.saMoreTab {
		padding: 0;
		border-radius: 0 0.25rem 0 0;

		.saBadgeCount {
			position: absolute;
			top: -0.25rem;
			right: -0.25rem;
		}
	}
}

.saIFrameTabs {
	.ContextMenu();
	.TabGroup();

	.saContextMenu button {
		width: 100%;
		background-color: @ColorWhite;
	}

	.saTabViewInner {
		position: relative;
		padding-top: 0.5rem;
	}

	.saTabGroup {
		margin-left: 1.5rem;
		width: calc(100% - 1.5rem);
	}

	.saMoreTabInner {
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 0.5rem;
		transition: ease all .2s;
		border-radius: 0.5rem;
		height: 2.5rem;
		width: 2.5rem;
	}

	.saMoreTab {
		.Hover({
			.saMoreTabInner {
				background: @ColorGray100;
			}
		});
	}

	.saMoreTab:active .saMoreTabInner {
		background-color: @ColorGray150;
	}

	.saMoreTab:active .saMoreTabInner .saIconHolder {
		transform: scale(0.96);
	}

	.saStandard & {
		.saTabViewInner {
			width: 100%;
		}

		.saContextMenu {
			top: 3.5rem;
		}
	}

	.saCompact & {
		.saTabViewInner {
			width: 100%;
		}

		.saContextMenu {
			top: 2.75rem;
		}
	}
}

.saLinkTabs {
	display: flex;
	justify-content: center;

	.saTabViewInner {
		position: relative;
		width: 100%;
		border-radius: 1rem;
		margin: 1rem;
		max-width: 100%;
		.Border();
	}

	.saTabGroup {
		display: flex;
		flex-direction: column;
		padding: 0.5rem;
		gap: 0.5rem;
		width: 100%;
		align-items: flex-start;
		box-sizing: border-box;

		.saAngleRight {
			display: flex;
			justify-self: flex-end;
			padding-right: 0.25rem;
		}

		&>li {
			width: 100%;
		}
	}

	.saTab {
		display: flex;
		position: relative;
		align-items: center;
		gap: 0.5rem;
		height: 3rem;
		min-width: 0;
		justify-content: space-between;
		width: 100%;
		padding: 0.5rem;
		border-radius: 0.5rem;
		transition: ease all 0.2s;
		color: var(--Sa-Color-Label);
		box-sizing: border-box;

		&::after {
			display: none;
		}

		.saIcon {
			color: var(--Sa-Color-Icon);
		}

		.Hover({
			background-color: var(--Sa-Color-MenuLinkHover);
			color: var(--Sa-Color-LabelHover);

			.saIcon {
				color: var(--Sa-Color-IconHover);
			}
		});

		&:active {
			color: var(--Sa-Color-LabelHover);
			background-color: var(--Sa-Color-MenuLinkActive);

			.saIcon {
				color: var(--Sa-Color-IconHover);
			}
		}
	}

	.saTabInner {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		min-width: 0;
	}

	.saTabInner .saIcon {
		display: flex;
		align-items: center;
		justify-content: center;
		min-width: 1.5rem;
	}

	.saTabText {
		font-size: 0.875rem;
		max-width: 32ch;
	}

	.saTabviewInner {
		display: none;
	}

	.BadgeCount();
}

.saMiniView {
	body& {
		overflow: hidden;
	}
}