.saEmptyState {
	.FlexCentered();
	gap: 1rem;
	flex-direction: column;
	padding: 1rem;
	color: var(--Sa-Color-Text);

	.saEmptyStateIcon {
		.FlexCentered();
		position: relative;
		height: 3rem;
		width: 3rem;
		border-radius: 0.5rem;
		background-color: @ColorGray150;

		.saIcon {
			color: @ColorGray600;
			font-size: 1.5rem;
			z-index: 1;
		}

		.saWarning& {
			background-color: @ColorYellow100;

			.saIcon {
				color: @ColorYellow300;
			}
		}
	}

	.saEmptyStateBody {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		align-items: center;
		justify-content: center;
		text-align: center;
	}

	.saEmptyStateHeading {
		font-size: 1rem;
		font-weight: 500;
	}

	.saEmptyStateDescription {
		font-size: 0.875rem;
		color: var(--Sa-Color-TextSecondary);
	}
}