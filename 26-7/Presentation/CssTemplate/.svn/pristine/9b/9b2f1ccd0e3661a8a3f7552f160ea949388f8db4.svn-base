.RadioButton() {
	input.saRadio {
		.AppearanceNone();
		background-color: @ColorWhite;
		margin: 0;
		padding: 0;
		font: inherit;
		min-width: @RadioButtonSize;
		height: @RadioButtonSize;
		border-radius: 50%;
		box-shadow: inset 0 0 0 2px @ColorGray500, 0 0 0 1px @ColorWhite;
		cursor: pointer;
		transition: ease background-color 0.2s, ease box-shadow 0.2s;
		position: relative;

		// Unchecked.
		&:enabled:not(:checked) {
			.Hover({
				background-color: @ColorBlue200;
				box-shadow: inset 0 0 0 2px @ColorBlue600, inset 0 0 0 6.1875rem @ColorBlue200, 0 0 0 1px @ColorWhite;
			});

			&:active {
				box-shadow: inset 0 0 0 2px @ColorBlue700,
					inset 0 0 0 6.1875rem @ColorBlue300, 0 0 0 1px @ColorWhite;
			}
		}

		&:disabled:not(:checked) {
			box-shadow: inset 0 0 0 2px @ColorGray200,
				inset 0 0 0 6.1875rem @ColorGray100, 0 0 0 1px @ColorWhite;
		}
	}

	input.saRadio:disabled {
		pointer-events: none;
		&+span {
			color: @ColorGray600;
		}
	}

	// Checked.
	input.saRadio:checked {
		box-shadow: inset 0 0 0 2px @ColorBlue700,
			inset 0 0 0 0.375rem @ColorBlue600, 0 0 0 1px @ColorWhite;

		&:disabled {
			background-color: @ColorGray300;
			pointer-events: none;
			box-shadow: inset 0 0 0 2px @ColorGray200,
				inset 0 0 0 0.375rem @ColorGray100, 0 0 0 1px @ColorWhite;
		}
	}
}

.RadioButtonErrorHover() {
	box-shadow: inset 0 0 0 2px @ColorRed700, inset 0 0 0 0.375rem @ColorRed600,
		0 0 0 1px @ColorWhite;
}

.RadioButtonWarningHover() {
	box-shadow: inset 0 0 0 2px @ColorYellow500, inset 0 0 0 0.375rem @ColorYellow300,
		0 0 0 1px @ColorWhite;
}
