.saTreeViewWrapper {
	display: block;
	.UserSelectNone();

	.saTreeView > li:has(ul) {
		&:first-child:after {
			top: 1rem;
			z-index: 1;
		}

		& > label::after {
			border-width: 0 0 1px 1px;
			border-color: fade(@ColorWhite, 0) fade(@ColorWhite, 0) @ColorGray200 fade(@ColorWhite, 0);
			z-index: 1;
		}
	}

	.saFileDropDescription {
		width: fit-content;
		height: 3rem;
		background: @ColorBlue50;
		border-radius: 0.5rem;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		border: 1px solid @ColorBlue600;
		padding: 0.5rem 0.75rem;
		color: @ColorGray900;
		box-sizing: border-box;
		margin-bottom: 0.5rem;

		.saIcon {
			font-size: 1.25rem;
			color: @ColorBlue600;
			background: url(../img/drag-and-drop.svg);
			width: 1.75rem;
			height: 2rem;
		}
	}

	.saTreeView.saRoot > li {
		&:first-child:after {
			display: none;
		}

		&>label::after {
			display: none;
		}
	}

	.saTreeView {
		display: flex;
		flex-direction: column;
		min-height: 2rem;
		.LoadingSpinner();

		.saLoadingSpinnerWrapper {
			display: flex;
			gap: 0.5rem;

			.saLoadingSpinner,
			.saLoadingSpinner::after {
				height: 1rem;
				width: 1rem;
			}

			&.saDone {
				.saLoading {
					display: flex;
				}

				.saLoadingSpinner {
					opacity: 0;
					border-top-color: fade(@ColorGreen400, 20);
					border-right-color: fade(@ColorGreen400, 20);
					border-bottom-color: fade(@ColorGreen400, 20);
					border-left-color: @ColorGreen400;
					animation: saLoadingSpinner .8s infinite linear, saLoadingSpinnerDone .8s forwards linear;
				}
			}
		}

		.saLoadingProgress {
			font-size: 0.75rem;
			color: @ColorGray600;
		}

		&.saDraggingFile {
			.saNodeContent {
				* {
					pointer-events: none;
				}
			}

			.saCanNotDropFile,
			&.saNoDrop {
				color: @ColorGray200;

				.saExpander {
					background-color: @ColorGray200;
				}

				i,
				.saDragHandle,
				span {
					color: @ColorGray200;
				}
			}

			.saFileDrop {
				background: @ColorBlue100;
				outline-color: @ColorBlue600;
			}
		}

		ul {
			flex-direction: column;
			width: 100%;
			flex: 1;
		}

		li {
			display: flex;
			flex-direction: column;
			overflow: visible;
			position: relative;

			&::after {
				content: '';
				position: absolute;
				height: calc(100% + 1.25rem);
				width: 1px;
				background: @ColorGray200;
				top: -1rem;
				left: 0.5rem;
				transition: ease all .2s;
			}
		}

		li.saDragged {
			border: none;
			background: inherit;

			&>label {
				background: @ColorWhite;
				outline: 1px solid @ColorBlue600;
				outline-offset: -1px;
			}
		}

		li.saDropOn {
			border: none;
			background: inherit;

			&>label {
				background: @ColorBlue100;
				outline-color: @ColorBlue600;
			}
		}


		& > li {
			&::after {
				top: 0.5rem;
				height: 100%;
			}

			label::after {
				height: 0.5rem;
			}
		}

		li:last-child::after {
			background: transparent;
		}

		li:only-child::after {
			background: @ColorGray200;
			height: 1.5rem;
		}

		input.saExpander {
			.FlexCentered();
			.AppearanceNone();
			height: 1rem;
			width: 1rem;
			min-width: 1rem;
			background: var(--Sa-Color-PrimaryButtonBackground);
			color: @ColorWhite;
			border-radius: 0.25rem;
			z-index: 2;
			border: none;
			position: relative;
			cursor: pointer;
			transition: ease background-color .2s, ease border-radius .2s, ;
			visibility: hidden;

			&::after {
				content: '';
				height: 2rem;
				width: 2rem;
				position: absolute;
			}

			&::before {
				content: '';
				clip-path: polygon(39% 4%, 61% 4%, 61% 39%, 96% 39%, 96% 56%, 61% 56%, 61% 96%, 39% 96%, 39% 56%, 4% 56%, 4% 39%, 39% 39%);
				cursor: default;
				background: @ColorWhite;
				.FlexCentered();
				height: 0.625rem;
				width: 0.625rem;
				position: absolute;
				inset: 0.1875rem;
				transition: ease all .2s;
			}

			&.saMinus:checked::before {
				clip-path: polygon(39% 39%, 61% 39%, 61% 39%, 96% 39%, 96% 56%, 61% 56%, 61% 56%, 39% 56%, 39% 56%, 4% 56%, 4% 39%, 39% 39%);
			}

			.Hover({
				background: var(--Sa-Color-PrimaryButtonBackgroundHover);
			});

			&:active {
				background: var(--Sa-Color-PrimaryButtonBackgroundActive);
				border-radius: 0.375rem;
			}
		}

		.saExpandIconDiv {
			background: @ColorGray400;
			color: @ColorWhite;
			.FlexCentered();
			border-radius: 0.25rem;
			position: relative;
			margin: 0.1875rem 0.1875rem 0.1875rem 0.2813rem;
			width: 1rem;
			height: 1rem;
			z-index: 2;
			cursor: wait;
			visibility: hidden;
		}

		.saExpandIcon {
			position: absolute;
			font-size: 0.75rem;
		}

		label.saNodeExpand .saExpander {
			visibility: visible;

			&:disabled {
				background: @ColorGray400;
				cursor: default;
			}
		}

		li label {
			display: flex;
			gap: 0.5rem;
			align-items: center;
			padding-left: 0.5rem;
			min-height: 2rem;
			position: relative;
			font-size: 0.875rem;
			line-height: 1.25rem;
			white-space: break-spaces;
			overflow-wrap: break-word;
			border-radius: 0.5rem;
			padding-right: 0.5rem;
			transition: ease border-radius .2s;
			outline: 2px dashed transparent;
			outline-offset: -2px;

			&.saNodeExpand {
				cursor: pointer;
			}

			a {
				min-height: 2rem;
				width: 100%;
				text-decoration: none;
				color: var(--Sa-Color-Link);
				font-weight: 500;

				.Hover({
					text-decoration: underline;
				});

				&:focus-visible {
					box-shadow: 0 0 0 1px black;
				}
			}

			.saCustomColor a {
				color: unset;
			}

			label {
				display: flex;
				gap: 0.5rem;
				width: 100%;
				cursor: pointer;
			}

			&::after {
				content: '';
				position: absolute;
				height: 1rem;
				width: 1.4375rem;
				margin-left: -1px;
				border: 1px solid @ColorGray200;
				z-index: 1;
				border-width: 0 0 1px 1px;
				transform: translate(-0.25rem, -0.5rem);
				transition: ease all .2s;
			}
		}

		li:not(.saDragged) > label {
			.Hover({
				background: @ColorGray100;
			});
		}
	}

	ul.saTreeView {
		.recursiveTree(1, 100);
	}

	.recursiveTree(@i, @n) when (@i =< @n) {
		li {
			.recursiveTree(@i + 2, @n);

			&::after {
				left: (0.5rem * @i - 0.3125rem);
			}

			label {
				padding-left: (0.5rem * @i);
			}
		}
	}

	.saTreeViewButtons {
		display: flex;
		gap: 0.5rem;
		justify-self: flex-end;
	}

	.saDragHandle {
		.FlexCentered();
		height: 1.5rem;
		min-width: 0.75rem;
		font-size: 1.25rem;
		color: @ColorGray600;

		.Hover({
			cursor: grab;
		});

		&:active {
			cursor: grabbing;
		}
	}

	button.saTreeViewButton {
		.FlexCentered();
		.ButtonSecondary();
		border-radius: 0.25rem;
		height: 1.5rem;
		width: 1.5rem;
		min-width: 1.5rem;
		cursor: pointer;
		text-align: center;
		font-size: 0.875rem;
		line-height: 0.875rem;
		transition: ease background .2s, ease border .2s, ease border-radius .2s, ease color .2s;

		&:active {
			border-radius: 0.5rem;
		}

		&::after {
			content: '';
			height: 2rem;
			width: 2rem;
			position: absolute;
		}
	}

	.saSortable {
		li:active::after {
			background: transparent;
		}

		label:active {
			&::after {
				border: transparent;
			}
		}
	}

	.saSmallScreen .saMultiPartContent & {
		padding: 0;
	}

	.saSmallScreen & {
		padding: 1rem 1rem 1rem 0.5rem;

		ul.saTreeView > li[aria-expanded]:first-child:after {
			top: 1.5rem;
		}

		ul.saTreeView li label::after {
			height: 3rem;
			transform: translate(-0.25rem, -1.5rem);
		}

		ul.saTreeView li label {
			min-height: 3rem;
			gap: 0.75rem;
			overflow-wrap: anywhere;

			a {
				min-height: 3rem;
				line-height: 3rem;
			}
		}

		.saTreeViewPlaceholder {
			min-height: 3rem;
		}

		button.saTreeViewButton {
			border-radius: 0.5rem;
			height: 2rem;
			min-width: 2rem;
			font-size: 1rem;
			line-height: 1rem;
			transition: ease all .2s;

			&:active {
				border-radius: 0.75rem;
			}

			&::after {
				content: '';
				height: 3rem;
				width: 3rem;
				position: absolute;
			}
		}
	}
}