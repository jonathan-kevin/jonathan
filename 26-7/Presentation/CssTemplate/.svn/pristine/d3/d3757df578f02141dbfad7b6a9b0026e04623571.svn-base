.saInfoArea {
	display: block;
}

.InfoBoxControlHeading() {
	font-size: 0.875rem;
	font-weight: 500;
	display: flex;
	gap: 0.5rem;
	align-items: baseline;
}

.saInfoBoxArea {
	display: flex;
	flex-direction: column;
	justify-content: center;
	background: @ColorWhite;
	border-radius: 1rem;
	padding: 1rem;
	.Border();

	.saInfoBox {
		display: flex;
		flex-direction: column;
		position: relative;
		gap: 1rem;

		img {
			max-width: 100%;
			object-fit: contain;
		}

		&.saOpen .saInfoBoxExpandIcon {
			transform: rotate(180deg);
		}

		&.saClosed {
			.saInfoBoxInner {
				display: none;
			}

			.saInfoBoxExpandIcon {
				transform: rotate(0deg);
			}
		}

		&:not(:last-child)::after {
			content: "";
			position: absolute;
			left: 0;
			height: 1px;
			border-radius: 1px;
			width: 100%;
			background: @ColorGray200;
			bottom: -1rem;
		}

		.infosqlexternalframe {
			border: 1px solid @ColorGray150;
			width: 100%;
			box-sizing: border-box;
		}
	}

	.saInfoBoxHeading {
		display: flex;
		justify-content: space-between;
		align-items: center;
		word-break: break-word;
		gap: 0.5rem;
		margin: -0.5rem 0;

		&.saInfoBoxHeadingButton {
			background: transparent;
			border-radius: 0.5rem;
			width: calc(100% + 1rem);
			padding: 0 0.5rem;
			margin-left: -0.5rem;
			text-align: left;
			position: relative;
			.StandardTransition();

			.Hover({
				background: @ColorGray50;

				h3 {
					color: var(--Sa-Color-LabelHover);
				}

				.saIcon {
					color: var(--Sa-Color-IconHover);
				}
			});

			&:active {
				background: @ColorGray100;
				border-radius: 0.75rem;

				h3 {
					color: var(--Sa-Color-LabelHover);
				}

				.saIcon {
					color: var(--Sa-Color-IconHover);
				}
			}

			&::after {
				content: '';
				position: absolute;
				height: 100%;
				min-height: 3rem;
				width: calc(100% + 1rem);
				left: -0.5rem;
				min-width: 3rem;
				background-color: transparent;
				opacity: 0;
				user-select: none;
			}

			.saInfoBoxExpandIcon {
				.FlexCentered();
				color: var(--Sa-Color-Icon);
				font-size: 1rem;
				height: 2rem;
				width: 2rem;
				min-width: 2rem;
				margin-right: -0.5rem;
				transition: transform 0.2s ease;
			}
		}

		a {
			.Link();
		}

		h3 {
			color: var(--Sa-Color-Label);
			flex-grow: 1;
		}

		.saInfoBoxHeaderIcon {
			.BadgedIconSmall();
		}

		a {
			text-decoration: none;
			cursor: pointer;
			transition: all 0.2s ease;
		}

		a,
		.saInfoBoxHeaderWrapper {
			display: flex;
			gap: 0.5rem;
			align-items: center;
		}
	}

	.saInfoBoxInner {
		display: flex;
		flex-direction: column;
		transition: transform 0.2s ease, height 0.2s ease, opacity 0.2s ease;
		word-break: break-word;
		gap: 1rem;

		.saCompact & {
			gap: 0.75rem;
		}

		a {
			.Link();
		}
	}

	.saInfoBoxGrid {
		display: grid;
		grid-template-columns: 34% fit-content(66%);
		grid-column-gap: 1rem;
		grid-row-gap: 1rem;

		.saCompact & {
			grid-row-gap: 0.75rem;
		}

		.saInfoBoxLabel {
			margin-top: 1px;
			margin-bottom: 1px;
		}
	}

	.saInfoBoxContent {
		color: @ColorGray900;

		&.saRightAlign {
			text-align: right;
		}
	}

	.saInfoBoxLabel {
		color: var(--Sa-Color-InfoBoxLabel);
		font-size: 0.75rem;
		display: flex;
		gap: 0.5rem;
		.AiIcon();
	}

	.saInfoBoxCol {
		display: flex;
		flex-direction: column;

		@keyframes clip {
			to {
				background-position: -200% center;
			}
		}
	}

	.saInfoBoxCol:has(.saAiIcon:hover) .saInfoBoxTextContent,
	.saInfoBoxCol:has(.saAiIcon:focus-visible) .saInfoBoxTextContent {
		.AiIconHoverAnimation();
	}

	.saInfoBoxImage {
		display: flex;
		justify-content: center;
	}

	.saInfoSqlKpiWrapper {
		display: flex;
		flex-direction: row;
		align-items: flex-end;
		gap: 1rem;
		width: 100%;
		flex-wrap: wrap;
		overflow: hidden;
	}

	.saRowWrapper {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.saRowWrapper:not(:first-child)::before {
		content: '';
		position: relative;
		top: 0;
		height: 1px;
		width: 100%;
		border-radius: 1px;
		background: @ColorGray200;
		top: 1rem;
	}

	.saColWrapper {
		display: flex;
		flex-direction: row;
		gap: 2rem;
	}

	.saCol {
		position: relative;
		display: flex;
		flex-direction: column;
		flex: 1 1 100%;
		transition: all 0.2s ease;
		gap: 2rem;

		.systemicon {
			top: 1px;
			position: relative;
			padding-right: 0.1875rem;

			.saIcon {
				min-width: 1.25rem;
				text-align: center;
			}
		}

		&:not(:last-child)::after {
			content: '';
			position: absolute;
			top: 0;
			height: 100%;
			width: 1px;
			border-radius: 1px;
			background: @ColorGray200;
			right: -1rem;
		}
	}

	.saExpandButton {
		.Button();
		.ButtonGhost();
		.IconButtonSizeCompact();
		margin-right: -0.5rem;

		.saIcon {
			transition: transform 0.2s ease;
			position: relative;
		}

		&::after {
			content: '';
			height: 3rem;
			width: 3rem;
			position: absolute;
			opacity: 0;
			background-color: transparent;
		}
	}

	/* Use simple style for user content while we have CSS resets. */
	.saUserHtmlContent {
		.UserHtmlContent();
		overflow-x: auto;

		* {
			white-space: normal !important;
			word-break: normal !important;
			overflow-wrap: break-word !important;
		}

		pre * {
			white-space: pre !important;
		}

		table {
			max-width: 100%;
		}
	}
}

.saInfoArea {
	.saWarningArea {
		padding-bottom: 1px; // Make sure JavaScript calculations use the whole height, as margins are excludes otherwise.
	}

	.saWarningBox {
		display: flex;
		flex-direction: row;
		gap: 0.5rem;
		padding: 0.5rem;
		margin-bottom: 1rem;
		border-radius: 0.5rem;
		color: @ColorGray900;
		overflow: hidden;

		.saIcon {
			font-size: 1.25rem;
			min-width: 2rem;
			display: flex;
			align-items: center;
			justify-content: center;
			flex: 0 0 auto;
		}

		.saContent {
			align-self: center;
			word-break: break-word;
			flex: 0 1 auto;
			display: flex;
			flex-direction: column;
			min-width: 8rem; // MUST set a min width on the content for flex-shrink to work.
			font-weight: 500;
		}

		&.saClosed.saExpandable .saContent {
			.Ellipsis();
			max-height: 1lh;
			word-break: break-all;

			* {
				display: none;

				&:first-child {
					display: unset; // Show the first line.
				}
			}
		}

		.saActionWrapper {
			flex: 0 0 auto;
			padding-top: 0.375rem;
		}

		.saButtons {
			display: flex;
			flex: 0 0 auto;
		}

		.saPadding {
			flex: 1 0 auto;
		}

		.saClose {
			font-size: 1rem;
			flex: 0 0 auto;
		}

		.saWarningButton {
			.Button();
			.IconButtonSizeCompact();
			color: @ColorGray600;
			position: relative;
			background-color: transparent;

			&::after {
				content: '';
				height: 3rem;
				width: 2.75rem;
				position: absolute;
				top: -0.5rem;
				right: -0.5rem;
			}

			.Hover({
				color: @ColorWhite;
			});
		}

		.saClose .saWarningButton {
			.Hover({
				background: @ColorRed600;
			});

			&:active {
				background: @ColorRed700;
			}
		}

		.saWarningExpander .saWarningButton {
			&::after {
				right: unset;
				left: -0.875rem;
			}
		}

		.saWarningExpander.saOpen i {
			transform: rotate(180deg);
		}

		&.saError {
			background: @ColorRed50;
			border: 1px solid @ColorRed600;

			.saIcon {
				color: @ColorRed600;
			}

			.saWarningExpander .saWarningButton {
				.Hover({
					background: @ColorRed600;
				});

				&:active {
					background: @ColorRed700;
				}
			}
		}

		&.saWarning {
			background: @ColorYellow50;
			border: 1px solid @ColorYellow300;

			.saIcon {
				color: @ColorYellow300;
			}

			.saWarningExpander .saWarningButton {
				.Hover({
					background: @ColorYellow600;
				});

				&:active {
					background: @ColorYellow700;
				}
			}
		}

		&.saInfo {
			background: @ColorBlue50;
			border: 1px solid @ColorBlue600;

			.saIcon {
				color: @ColorBlue600;
			}

			.saWarningExpander .saWarningButton {
				.Hover({
					background: @ColorBlue600;
				});

				&:active {
					background: @ColorBlue700;
				}
			}
		}

		&.saSuccess {
			background: @ColorGreen50;
			border: 1px solid @ColorGreen400;

			.saIcon {
				color: @ColorGreen400;
			}

			.saWarningExpander .saWarningButton {
				.Hover({
					background: @ColorGreen600;
				});

				&:active {
					background: @ColorGreen700;
				}
			}
		}

		.saWarningExpander {
			position: relative;
			font-size: 1rem;
			display: none;
		}

		&.saExpandable .saWarningExpander {
			display: flex;
		}

		.saAction {
			color: var(--Sa-Color-Link);
			font-weight: 700;
			cursor: pointer;

			.Hover({
				text-decoration: underline;
			});

			&:active {
				color: var(--Sa-Color-Link-Brightness80);
			}

			.saSmallScreen &.saDesktopOnly {
				display: none;
			}

			.saLargeScreen &.saSmallScreenOnly {
				display: none;
			}
		}
	}
}

.saMultiPartContent .saInfoBoxAreaWrapper {
	padding-bottom: 1rem;
}

.saMultiPartContent .saInfoBoxArea {
	border-radius: 0.5rem;
}

.saMultiPartContent .saInfoArea:last-child .saInfoBoxAreaWrapper {
	padding-bottom: 0;
}

.saPopup .saInfoBoxAreaWrapper {
	padding-bottom: @InfoBoxAreaPopupPadding;
}

.saInfoBoxAreaWrapper {
	padding-bottom: @InfoBoxAreaPadding;
	/* Must be padding and not margin for the tabview calculations to get the correct height */

	&.saInfoBoxAreaBelow {
		padding-bottom: 0;
		padding-top: @InfoBoxAreaPadding;
	}

	.saSmallScreen &.saNoBottomMargin {
		padding-bottom: 0;
	}
}

.saLargeScreen {
	.saInfoArea .saWarningBox:last-child {
		margin-bottom: @InfoBoxAreaPadding;
	}

	&.saPopup .saInfoArea .saWarningBox:last-child {
		margin-bottom: @InfoBoxAreaPopupPadding;
	}

	.saInfoBoxArea {
		.saExpandButton {
			user-select: none;
			background-color: transparent;

			.Hover({
				color: @ColorBlue600;
				background-color: @ColorGray50;
			});

			&:focus-visible {
				color: @ColorBlue600;
				background-color: @ColorGray50;
			}

			&:active {
				background-color: @ColorGray100;
			}
		}
	}
}

.saSmallScreen {
	.saWarningArea {
		margin-bottom: 1rem;

		.saWarningBox:last-child {
			margin-bottom: 0;
		}
	}

	.saInfoArea:first-child .saInfoBoxArea {
		margin-top: 1rem;
	}

	.saInfoBoxArea {
		margin: 0 1rem;

		.saRowWrapper,
		.saColWrapper {
			gap: 3rem;
		}

		.saRowWrapper::before {
			top: 1rem;
		}

		.saCol {
			gap: 2rem;

			&::after {
				right: -1rem;
			}
		}

		.saInfoBox::after {
			bottom: -1rem;
		}
	}

	.saWarningBox {
		margin: 1rem;
	}
}